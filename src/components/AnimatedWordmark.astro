---
// "tammo — STUDIOS." als animierte Wordmark.
// 2-Zeilen-Layout wie das Logo-PNG:
//   Zeile 1: tammo (Neue Montreal Bold)
//   Zeile 2: Bar + STUDIOS. (Aileron Black Italic)
// Steuerung: ausschließlich über CSS-Variablen (--char-progress pro
// Char, --settle-progress auf der ganzen Wordmark), gesetzt vom
// Section2-Scroll-Listener. Komponente ist passiv.
---

<h2 class="wordmark" aria-label="Tammo Studios">
  <span class="wm-line wm-line-top">
    <span class="wm-block wm-tammo">
      <span class="char" style="--i: 0;">t</span>
      <span class="char" style="--i: 1;">a</span>
      <span class="char" style="--i: 2;">m</span>
      <span class="char" style="--i: 3;">m</span>
      <span class="char" style="--i: 4;">o</span>
    </span>
  </span>
  <span class="wm-line wm-line-bottom">
    <span class="wm-block wm-dash">
      <span class="char wm-bar" style="--i: 5;" aria-hidden="true"></span>
    </span>
    <span class="wm-block wm-studios">
      <span class="char" style="--i: 6;">S</span>
      <span class="char" style="--i: 7;">T</span>
      <span class="char" style="--i: 8;">U</span>
      <span class="char" style="--i: 9;">D</span>
      <span class="char" style="--i: 10;">I</span>
      <span class="char" style="--i: 11;">O</span>
      <span class="char" style="--i: 12;">S</span>
      <span class="char" style="--i: 13;">.</span>
    </span>
  </span>
</h2>

<style>
  .wordmark {
    --settle-progress: 0;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: clamp(3rem, 9vw, 7rem);
    color: #f5f5f4;
    line-height: 0.95;
    margin: 0;
    /* Settled-State: scroll-driven brightness + drop-shadow Atmen.
       --settle-progress 0 = identity, 1 = voller Glow. */
    filter:
      brightness(calc(1 + var(--settle-progress) * 0.1))
      drop-shadow(0 0
                  calc(var(--settle-progress) * 30px)
                  rgba(245, 158, 11, calc(var(--settle-progress) * 0.5)));
  }

  .wm-line {
    display: flex;
    align-items: baseline;
  }

  /* Optisch angepasst zum Match des Logo-PNG: tammo dominiert die obere
     Zeile, Bar + STUDIOS sitzen kompakter mit leichtem Overlap nach oben.
     justify-content: flex-start sichert, dass die Bar wirklich am linken
     Rand klebt — egal wie schmal der Wordmark-Block durch das kleinere
     STUDIOS wird. */
  .wm-line-bottom {
    align-items: center;
    justify-content: flex-start;
    margin-top: -0.1em;
    gap: 0.15em;
  }

  .wm-block {
    display: inline-flex;
  }

  .wm-block.wm-dash {
    align-items: center;
    margin-left: 0;
  }

  .wm-tammo {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  /* Im Logo-PNG ist STUDIOS deutlich kleiner als tammo. font-size relativ
     zum Wordmark-em, damit clamp() weiterhin die Skalierung steuert.
     0.48em ist optisch kalibriert: damit endet der "." von STUDIOS bündig
     mit dem "o" von tammo. */
  .wm-studios {
    font-family: 'Aileron', 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    letter-spacing: -0.02em;
    font-size: 0.48em;
  }

  /* Per-Char Progress 0..1 wird vom Section2-Script gesetzt.
     Position, Sichtbarkeit, Schärfe und Glow leiten sich linear ab.
     Vier-Layer-Glow inkl. heller Goldton (#fcd34d) für äußere Tiefe. */
  .char {
    --char-progress: 0;
    display: inline-block;
    transform: translateY(calc((1 - var(--char-progress)) * 100%));
    opacity: var(--char-progress);
    filter: blur(calc((1 - var(--char-progress)) * 6px));
    text-shadow:
      0 0 calc(var(--char-progress) * 40px)
        rgba(245, 158, 11, calc(var(--char-progress) * 0.7)),
      0 0 calc(var(--char-progress) * 100px)
        rgba(245, 158, 11, calc(var(--char-progress) * 0.5)),
      0 0 calc(var(--char-progress) * 200px)
        rgba(245, 158, 11, calc(var(--char-progress) * 0.25)),
      0 0 calc(var(--char-progress) * 300px)
        rgba(252, 211, 77, calc(var(--char-progress) * 0.10));
    will-change: transform, opacity, filter;
  }

  /* Custom Bar als Dash — länger & dicker, näher am Logo-PNG.
     Translation-Distanz 1em, weil 100% von der Mini-Höhe quasi nichts
     wäre und der Bar sonst nur "blink-on" statt einfliegen würde.
     Optisch kalibriert zum Match des Logo-PNG. */
  .char.wm-bar {
    width: 0.85em;
    height: 0.13em;
    background: currentColor;
    margin: 0;
    align-self: center;
    transform: translateY(calc((1 - var(--char-progress)) * 1em));
    /* text-shadow rendert nichts auf einem Bar ohne Inhalt → eigener
       box-shadow Glow, parallel zum Char-Glow. */
    box-shadow:
      0 0 calc(var(--char-progress) * 24px)
        rgba(245, 158, 11, calc(var(--char-progress) * 0.6)),
      0 0 calc(var(--char-progress) * 60px)
        rgba(245, 158, 11, calc(var(--char-progress) * 0.35));
  }

  @media (max-width: 380px) {
    .wordmark {
      font-size: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .char {
      --char-progress: 1 !important;
    }
    .wordmark {
      --settle-progress: 1 !important;
    }
  }
</style>
