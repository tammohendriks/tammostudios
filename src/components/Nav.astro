---
import { SITE, NAV_ITEMS, CTA } from '../lib/constants';
---

<div id="nav-sentinel" aria-hidden="true"></div>

<header
  id="nav-header"
  class="nav-header sticky top-0 z-50 border-b border-white/5 bg-ts-bg/80 backdrop-blur-md"
  transition:persist="nav"
>
  <div class="relative mx-auto flex max-w-6xl flex-col items-center px-4 py-4 sm:py-5">
    <a href="/" class="logo-link flex items-center justify-center" aria-label={SITE.name}>
      <img
        src="/logos/logo-full.png"
        alt={SITE.name}
        class="nav-logo block w-auto select-none"
        draggable="false"
      />
    </a>

    <ul class="desktop-nav mt-4 hidden items-center gap-8 md:flex">
      {NAV_ITEMS.map((item) => (
        <li>
          <a href={item.href} class="nav-link text-sm font-medium tracking-wide text-ts-fg">
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a href={CTA.href} class="cta-pill text-sm font-medium tracking-wide">
          {CTA.label}
        </a>
      </li>
    </ul>

    <button
      id="nav-toggle"
      class="hamburger md:hidden"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu md:hidden" hidden>
  <ul class="flex flex-col items-center gap-8 px-6">
    {NAV_ITEMS.map((item) => (
      <li>
        <a href={item.href} class="text-2xl font-medium text-ts-fg">{item.label}</a>
      </li>
    ))}
    <li class="mt-2">
      <a href={CTA.href} class="cta-pill text-base font-medium tracking-wide">
        {CTA.label}
      </a>
    </li>
  </ul>
</div>

<style>
  .nav-header {
    animation: nav-enter 600ms cubic-bezier(0.2, 0.6, 0.2, 1) both;
  }

  .nav-logo {
    max-height: 64px;
    transition: max-height 280ms ease;
  }

  :global(body.is-shrunk) .nav-logo {
    max-height: 40px;
  }

  @media (max-width: 767px) {
    .nav-logo {
      max-height: 48px;
    }
    :global(body.is-shrunk) .nav-logo {
      max-height: 36px;
    }
  }

  .nav-link {
    position: relative;
    padding: 4px 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-ts-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .nav-link:hover {
    color: rgba(245, 245, 244, 0.85);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    transform: scaleX(1);
  }

  .cta-pill {
    display: inline-block;
    padding: 10px 24px;
    border-radius: 9999px;
    background: var(--color-ts-accent);
    color: var(--color-ts-bg);
    box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5);
    animation: pulse-cta 2.4s ease-out infinite;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .cta-pill:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  @keyframes pulse-cta {
    0%   { box-shadow: 0 0 0 0    rgba(245, 158, 11, 0.5); }
    70%  { box-shadow: 0 0 0 14px rgba(245, 158, 11, 0);   }
    100% { box-shadow: 0 0 0 0    rgba(245, 158, 11, 0);   }
  }

  .hamburger {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    background: transparent;
    border: 0;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ts-fg);
    transition: transform 220ms ease, opacity 220ms ease;
    transform-origin: center;
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 12, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: menu-enter 220ms ease-out;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  @keyframes nav-enter {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes menu-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-header,
    .mobile-menu,
    .cta-pill,
    .nav-logo,
    .hamburger span {
      animation: none;
      transition: none;
    }
    .cta-pill {
      box-shadow: none;
    }
  }
</style>

<script>
  // Scroll-shrink: Sentinel oben verlässt Viewport → body bekommt is-shrunk
  const sentinel = document.getElementById('nav-sentinel');
  if (sentinel) {
    const io = new IntersectionObserver(
      ([entry]) => {
        document.body.classList.toggle('is-shrunk', !entry.isIntersecting);
      },
      { threshold: 0 },
    );
    io.observe(sentinel);
  }

  // Mobile-Menu Toggle
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const isOpen = () => !menu.hasAttribute('hidden');
    const open = () => {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });

    // Falls Viewport von mobil → desktop wechselt während offen
    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches && isOpen()) close();
    });
  }
</script>
