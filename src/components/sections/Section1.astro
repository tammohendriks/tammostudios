---
import { SITE, SITE_LABELS } from '../../lib/constants';
import Background from '../Background.astro';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-1">
  <Background />

  <h1 class="logo-wrap">
    <img
      src="/logos/logo-full.png"
      alt={SITE.name}
      class="logo-img"
      draggable="false"
      fetchpriority="high"
    />
  </h1>
  <p class="hero-service">{SITE_LABELS.serviceLine}</p>
  <p class="intro">{SITE_LABELS.introText}</p>

  <ScrollCue />
</section>

<style is:global>
  /* Anti-FOUC: alle animierten Hero-Elemente sind PER DEFAULT versteckt,
     komplett unabhängig vom data-splash-Attribut. Falls das Inline-Script
     in BaseLayout aus irgendeinem Grund nicht greift (sessionStorage in
     Private Mode wirft, JS deaktiviert für einen Moment, etc.), sehen
     wir trotzdem nichts aufblitzen. Sichtbar wird's nur durch
     html[data-splash="ready"] oder html.splash-skip. */

  .background {
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }

  .top-left,
  .nav,
  .cta,
  .hero-service,
  .intro,
  .scroll-cue {
    opacity: 0;
    transform: translateY(8px);
  }

  /* Reveal-Phase: Background fadet ein, Hero-Texte bleiben noch hidden. */
  html[data-splash="reveal"] .background,
  html[data-splash="ready"]  .background {
    opacity: 1;
  }

  /* Ready-Phase: alle Hero-Elemente faden gestaffelt ein. */
  html[data-splash="ready"] .top-left,
  html[data-splash="ready"] .nav,
  html[data-splash="ready"] .cta,
  html[data-splash="ready"] .hero-service,
  html[data-splash="ready"] .intro,
  html[data-splash="ready"] .scroll-cue {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  html[data-splash="ready"] .top-left      { transition-delay: 0ms;   }
  html[data-splash="ready"] .nav           { transition-delay: 80ms;  }
  html[data-splash="ready"] .cta           { transition-delay: 160ms; }
  html[data-splash="ready"] .hero-service  { transition-delay: 220ms; }
  html[data-splash="ready"] .intro         { transition-delay: 280ms; }
  html[data-splash="ready"] .scroll-cue    { transition-delay: 360ms; }

  /* Returning visitor / reduced-motion: alles sofort sichtbar, keine
     Transitions. Höhere Specifity als die Default-Hidden-Regeln. */
  html.splash-skip .background,
  html.splash-skip .top-left,
  html.splash-skip .nav,
  html.splash-skip .cta,
  html.splash-skip .hero-service,
  html.splash-skip .intro,
  html.splash-skip .scroll-cue {
    opacity: 1;
    transform: none;
    transition: none;
  }
</style>

<style>
  .section-1 {
    position: relative;
    overflow: hidden;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    text-align: center;
  }

  .logo-wrap {
    position: relative;
    z-index: 5;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .logo-img {
    display: block;
    height: 38vh;
    width: auto;
    max-width: 80vw;
    filter:
      drop-shadow(0 0 40px rgba(245, 158, 11, 0.25))
      drop-shadow(0 0 90px rgba(245, 158, 11, 0.12));
    animation: logo-glow 6s ease-in-out infinite;
  }

  @media (max-width: 767px) {
    .logo-img {
      height: 25vh;
    }
  }

  @keyframes logo-glow {
    0%, 100% {
      filter:
        drop-shadow(0 0 40px rgba(245, 158, 11, 0.25))
        drop-shadow(0 0 90px rgba(245, 158, 11, 0.12));
    }
    50% {
      filter:
        drop-shadow(0 0 60px rgba(245, 158, 11, 0.36))
        drop-shadow(0 0 130px rgba(245, 158, 11, 0.20));
    }
  }

  /* Service-Zeile: zwischen Logo und Intro, deutlich präsenter als
     der Subtext darunter. Hierarchie Logo > Service > Intro. */
  .hero-service {
    position: relative;
    z-index: 5;
    margin: 28px 0 14px;
    max-width: 640px;
    color: #f5f5f4;
    font-family: 'Neue Montreal', 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .intro {
    position: relative;
    z-index: 5;
    margin: 0;
    max-width: 520px;
    color: rgba(245, 245, 244, 0.7);
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .hero-service {
      max-width: 480px;
    }
    .intro {
      font-size: 13px;
      max-width: 360px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-img {
      animation: none;
    }
  }
</style>

<script>
  // Splash-State-Maschine. Das Inline-Script in BaseLayout hat ggf. schon
  // html.splash-skip gesetzt (returning visitor / reduced-motion) — dann
  // bleibt data-splash leer und CSS-Defaults greifen sofort.
  const html = document.documentElement;
  if (!html.classList.contains('splash-skip')) {
    try { sessionStorage.setItem('ts-splash-seen', '1'); } catch (e) {}
    window.setTimeout(() => { html.setAttribute('data-splash', 'reveal'); }, 1200);
    window.setTimeout(() => { html.setAttribute('data-splash', 'ready'); }, 2000);
  }
</script>
