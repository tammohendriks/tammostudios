---
import { SITE, SITE_LABELS } from '../../lib/constants';
import Background from '../Background.astro';
import ScrollCue from '../ScrollCue.astro';

// Floating Particles — pro Build neu randomisiert. deltaX/Y in vw/vh,
// damit translate() in Viewport-Distanz arbeitet (transform: translate(%)
// wäre element-relativ und damit für 2–4px Punkte praktisch zero).
const PARTICLE_COUNT = 18;
const particles = Array.from({ length: PARTICLE_COUNT }, () => {
  const startX = Math.random() * 100;
  const startY = Math.random() * 100;
  const endX = Math.random() * 100;
  const endY = Math.random() * 100;
  return {
    startX,
    startY,
    deltaX: endX - startX,
    deltaY: endY - startY,
    duration: 25 + Math.random() * 25,
    delay: -Math.random() * 50,
    size: 2 + Math.random() * 2,
    opacity: 0.5 + Math.random() * 0.5,
  };
});
---

<section class="section-1">
  <Background />

  <div class="section-1-aurora" aria-hidden="true">
    <div class="aurora-blob aurora-blob-1"></div>
    <div class="aurora-blob aurora-blob-2"></div>
    <div class="aurora-blob aurora-blob-3"></div>
  </div>

  <div class="floating-particles" aria-hidden="true">
    {particles.map((p) => (
      <span
        class="particle"
        style={`--start-x: ${p.startX}%; --start-y: ${p.startY}%; --delta-x: ${p.deltaX}vw; --delta-y: ${p.deltaY}vh; --duration: ${p.duration}s; --delay: ${p.delay}s; --size: ${p.size}px; --opacity: ${p.opacity};`}
      ></span>
    ))}
  </div>

  <h1 class="logo-wrap">
    <img
      src="/logos/logo-full.png"
      alt={SITE.name}
      class="logo-img"
      draggable="false"
      fetchpriority="high"
    />
  </h1>
  <p class="hero-service">{SITE_LABELS.serviceLine}</p>
  <p class="intro">{SITE_LABELS.introText}</p>

  <ScrollCue />
</section>

<style is:global>
  /* Anti-FOUC: alle animierten Hero-Elemente sind PER DEFAULT versteckt,
     komplett unabhängig vom data-splash-Attribut. Falls das Inline-Script
     in BaseLayout aus irgendeinem Grund nicht greift (sessionStorage in
     Private Mode wirft, JS deaktiviert für einen Moment, etc.), sehen
     wir trotzdem nichts aufblitzen. Sichtbar wird's nur durch
     html[data-splash="ready"] oder html.splash-skip. */

  .background {
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }

  .top-left,
  .nav,
  .cta,
  .hero-service,
  .intro,
  .scroll-cue {
    opacity: 0;
    transform: translateY(8px);
  }

  /* Reveal-Phase: Background fadet ein, Hero-Texte bleiben noch hidden. */
  html[data-splash="reveal"] .background,
  html[data-splash="ready"]  .background {
    opacity: 1;
  }

  /* Ready-Phase: alle Hero-Elemente faden gestaffelt ein. */
  html[data-splash="ready"] .top-left,
  html[data-splash="ready"] .nav,
  html[data-splash="ready"] .cta,
  html[data-splash="ready"] .hero-service,
  html[data-splash="ready"] .intro,
  html[data-splash="ready"] .scroll-cue {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  html[data-splash="ready"] .top-left      { transition-delay: 0ms;   }
  html[data-splash="ready"] .nav           { transition-delay: 80ms;  }
  html[data-splash="ready"] .cta           { transition-delay: 160ms; }
  html[data-splash="ready"] .hero-service  { transition-delay: 220ms; }
  html[data-splash="ready"] .intro         { transition-delay: 280ms; }
  html[data-splash="ready"] .scroll-cue    { transition-delay: 360ms; }

  /* Returning visitor / reduced-motion: alles sofort sichtbar, keine
     Transitions. Höhere Specifity als die Default-Hidden-Regeln. */
  html.splash-skip .background,
  html.splash-skip .top-left,
  html.splash-skip .nav,
  html.splash-skip .cta,
  html.splash-skip .hero-service,
  html.splash-skip .intro,
  html.splash-skip .scroll-cue {
    opacity: 1;
    transform: none;
    transition: none;
  }
</style>

<style>
  .section-1 {
    position: relative;
    overflow: hidden;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    text-align: center;
  }

  .logo-wrap {
    position: relative;
    z-index: 5;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .logo-img {
    display: block;
    height: 38vh;
    width: auto;
    max-width: 80vw;
    filter:
      drop-shadow(0 0 40px rgba(245, 158, 11, 0.25))
      drop-shadow(0 0 90px rgba(245, 158, 11, 0.12));
    animation: logo-glow 6s ease-in-out infinite;
  }

  @media (max-width: 767px) {
    .logo-img {
      height: 25vh;
    }
  }

  @keyframes logo-glow {
    0%, 100% {
      transform: scale(1);
      filter:
        drop-shadow(0 0 40px rgba(245, 158, 11, 0.25))
        drop-shadow(0 0 90px rgba(245, 158, 11, 0.12));
    }
    50% {
      transform: scale(1.025);
      filter:
        drop-shadow(0 0 60px rgba(245, 158, 11, 0.36))
        drop-shadow(0 0 130px rgba(245, 158, 11, 0.20));
    }
  }

  /* Service-Zeile: zwischen Logo und Intro, deutlich präsenter als
     der Subtext darunter. Hierarchie Logo > Service > Intro.
     Headline-glow läuft synchron mit logo-glow (beides 6s ease-in-
     out) — Logo + Headline atmen als ein Atem. */
  .hero-service {
    position: relative;
    z-index: 5;
    margin: 28px 0 14px;
    max-width: 640px;
    color: #f5f5f4;
    font-family: 'Neue Montreal', 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    letter-spacing: -0.01em;
    line-height: 1.3;
    animation: headline-glow 6s ease-in-out infinite;
  }

  @keyframes headline-glow {
    0%, 100% {
      text-shadow:
        0 0 20px rgba(245, 158, 11, 0.15),
        0 0 40px rgba(245, 158, 11, 0.08);
    }
    50% {
      text-shadow:
        0 0 30px rgba(245, 158, 11, 0.30),
        0 0 60px rgba(245, 158, 11, 0.15);
    }
  }

  .intro {
    position: relative;
    z-index: 5;
    margin: 0;
    max-width: 520px;
    color: rgba(245, 245, 244, 0.7);
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .hero-service {
      max-width: 480px;
    }
    .intro {
      font-size: 13px;
      max-width: 360px;
    }
  }

  /* === Aurora Layer: 3 (Desktop) bzw. 2 (Mobile) warme Wolken-Blobs
     driften langsam mit verschiedenen Tempi und Richtungen über den
     Hintergrund. mix-blend-mode: screen lässt sie mit Grid + Dots
     verschmelzen statt sie zu überdecken. */
  .section-1-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .aurora-blob-1 {
    width: 55vw;
    height: 55vw;
    top: 15%;
    left: 25%;
    background: radial-gradient(circle,
      rgba(245, 158, 11, 0.20) 0%,
      rgba(245, 158, 11, 0.08) 40%,
      transparent 70%);
    animation: aurora-drift-1 22s ease-in-out infinite;
  }

  .aurora-blob-2 {
    width: 45vw;
    height: 45vw;
    top: 40%;
    right: 20%;
    background: radial-gradient(circle,
      rgba(252, 211, 77, 0.15) 0%,
      rgba(252, 211, 77, 0.05) 40%,
      transparent 70%);
    animation: aurora-drift-2 30s ease-in-out infinite;
  }

  .aurora-blob-3 {
    width: 50vw;
    height: 50vw;
    bottom: 10%;
    left: 35%;
    background: radial-gradient(circle,
      rgba(217, 119, 6, 0.12) 0%,
      rgba(217, 119, 6, 0.04) 40%,
      transparent 70%);
    animation: aurora-drift-3 36s ease-in-out infinite;
  }

  @keyframes aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(8vw, -5vh) scale(1.1); }
    66%      { transform: translate(-6vw, 6vh) scale(0.95); }
  }

  @keyframes aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-10vw, 5vh) scale(1.15); }
  }

  @keyframes aurora-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(0.95); }
    25%      { transform: translate(5vw, -8vh) scale(1.1); }
    75%      { transform: translate(-7vw, -4vh) scale(1.05); }
  }

  /* === Floating Particles: 18 (Desktop) bzw. 9 (Mobile) Sterne
     floaten diagonal, jeder mit eigenem Tempo + Delay. Negative
     animation-delay setzt jeden Partikel an einer anderen Phase
     in den Cycle, sodass beim ersten Frame schon alle gleichmäßig
     verteilt sichtbar sind. */
  .floating-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 2;
  }

  .particle {
    position: absolute;
    top: var(--start-y);
    left: var(--start-x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: rgba(245, 158, 11, var(--opacity));
    box-shadow:
      0 0 6px rgba(245, 158, 11, 0.7),
      0 0 12px rgba(252, 211, 77, 0.4);
    animation: particle-drift var(--duration) linear infinite;
    animation-delay: var(--delay);
    will-change: transform, opacity;
  }

  @keyframes particle-drift {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    8%   { opacity: var(--opacity); }
    92%  { opacity: var(--opacity); }
    100% {
      transform: translate(var(--delta-x), var(--delta-y));
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .aurora-blob-3 { display: none; }
    .aurora-blob-1,
    .aurora-blob-2 { filter: blur(60px); }
    .particle:nth-child(n+10) { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-img,
    .hero-service {
      animation: none;
    }
    .aurora-blob {
      animation: none !important;
    }
    .particle {
      animation: none !important;
      opacity: 0.3 !important;
    }
  }
</style>

<script data-astro-rerun>
  // Splash-State-Maschine. Das Inline-Script in BaseLayout hat ggf. schon
  // html.splash-skip gesetzt (returning visitor / reduced-motion) — dann
  // bleibt data-splash leer und CSS-Defaults greifen sofort.
  //
  // data-astro-rerun: ClientRouter führt diesen Block bei jeder
  // Navigation zurück zur Landing erneut aus, sodass die Sequenz auch
  // dann läuft, wenn der User nicht direkt mit / einsteigt.
  const html = document.documentElement;
  if (!html.classList.contains('splash-skip')) {
    try { sessionStorage.setItem('ts-splash-seen', '1'); } catch (e) {}
    window.setTimeout(() => { html.setAttribute('data-splash', 'reveal'); }, 1200);
    window.setTimeout(() => { html.setAttribute('data-splash', 'ready'); }, 2000);
  }
</script>
