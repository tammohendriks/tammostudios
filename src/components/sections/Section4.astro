---
import { SECTION4 } from '../../lib/constants';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-4">
  <div class="section-4-sticky">
    <div class="section-4-video-wrap" aria-hidden="true">
      <video
        class="section-4-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source
          media="(min-width: 768px)"
          src="/videos/desktop.mp4"
          type="video/mp4"
        />
        <source src="/videos/mobile.mp4" type="video/mp4" />
      </video>
      <div class="section-4-scrim"></div>
    </div>

    <header class="section-4-header">
      <p class="section-4-eyebrow">{SECTION4.eyebrow}</p>
      <h2 class="section-4-title">{SECTION4.title}</h2>
    </header>

    <div class="section-4-timeline-wrap">
      <svg
        class="timeline-line"
        viewBox="0 0 4 1000"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <line x1="2" y1="0" x2="2" y2="1000" class="line-track" />
        <line
          x1="2"
          y1="0"
          x2="2"
          y2="1000"
          class="line-progress"
          pathLength="100"
        />
      </svg>

      <div class="phase-dot phase-dot-1" data-phase="0"></div>
      <div class="phase-dot phase-dot-2" data-phase="1"></div>
      <div class="phase-dot phase-dot-3" data-phase="2"></div>
      <div class="phase-dot phase-dot-4" data-phase="3"></div>
      <div class="phase-dot phase-dot-5" data-phase="4"></div>

      <div class="phases-container">
        {SECTION4.phases.map((phase, i) => (
          <article class={`phase phase-${i + 1}`} data-phase={i}>
            <div class="phase-side">
              <span class="phase-label">{phase.label}</span>
              <h3 class="phase-title">{phase.title}</h3>
              <p class="phase-body">
                {phase.body}
                {phase.link && (
                  <>
                    {' '}
                    <a href={phase.link.href}>{phase.link.label}</a>
                  </>
                )}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="section-4-scrollcue-wrap">
      <ScrollCue />
    </div>
  </div>
</section>

<style>
  .section-4 {
    position: relative;
    min-height: 350vh;
    overflow: clip;
    background: #050507;
  }

  @media (max-width: 768px) {
    .section-4 {
      min-height: 280vh;
    }
  }

  /* === Galaxy Video Background ===
     Liegt INSIDE des einen Sticky-Containers als absoluter Layer
     hinter dem Content. Single-sticky-Pattern verhindert das
     Engagement-Problem, das zwei sticky-Geschwister auslösen
     (zweite würde erst nach 100vh Flow-Offset pinnen). */
  .section-4-video-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .section-4-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate(-50%, -50%);
    filter: brightness(0.85) contrast(1.1) saturate(1.15);
  }

  .section-4-scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 90%),
      linear-gradient(
        180deg,
        rgba(5, 5, 7, 0.55) 0%,
        rgba(5, 5, 7, 0.4) 50%,
        rgba(5, 5, 7, 0.65) 100%
      );
    pointer-events: none;
  }

  /* === Sticky Container — 3-Row Grid: header / timeline / cue ===
     Single sticky element (jetzt FIRST child von section-4) → pinnt
     ab Section-Eintritt. 100px Top sichert Distanz zur fixed TopBar.
     Video lebt darin als position: absolute background. */
  .section-4-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 100px 40px 40px;
    z-index: 2;
  }

  @media (max-width: 768px) {
    .section-4-sticky {
      padding: 80px 20px 32px;
    }
  }

  /* === Header (grid-row 1, oben fix, fadet einmal ein) === */
  .section-4-header {
    --header-progress: 0;
    grid-row: 1;
    position: relative;
    z-index: 2;
    text-align: center;
    opacity: var(--header-progress);
    transform: translateY(calc((1 - var(--header-progress)) * 12px));
    will-change: transform, opacity;
  }

  .section-4-eyebrow {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    color: rgba(245, 158, 11, 0.85);
    text-transform: uppercase;
    margin: 0 0 6px;
  }

  .section-4-title {
    font-family: 'Aileron', 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(1.3rem, 2.5vw, 1.85rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* === Timeline-Wrap (grid-row 2, vertikal zentriert in der 1fr Zelle) === */
  .section-4-timeline-wrap {
    grid-row: 2;
    align-self: center;
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
  }

  /* Linie spannt 18%-82% des Wraps. Dots sitzen 18/34/50/66/82,
     also genau auf den Linien-Endpunkten und Quartilen. Dadurch
     bleibt 18% Pufferzone oben (zum Header) und 18% unten (zur
     ScrollCue) — keine Kollision. */
  .timeline-line {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 64%;
    pointer-events: none;
    overflow: visible;
    z-index: 1;
  }

  .line-track {
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 2;
  }

  .line-progress {
    stroke: rgba(245, 158, 11, 0.85);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    filter: drop-shadow(0 0 6px rgba(245, 158, 11, 0.6));
  }

  /* Dots äquidistant (10/30/50/70/90). Dot 3 ist visuelles Zentrum,
     genau auf Höhe der Phasen-Inhalte. */
  .phase-dot {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.10);
    border: 2px solid rgba(245, 158, 11, 0.30);
    transition:
      background-color 300ms ease,
      border-color 300ms ease,
      box-shadow 300ms ease,
      transform 300ms ease;
    z-index: 2;
  }

  .phase-dot-1 { top: 18%; }
  .phase-dot-2 { top: 34%; }
  .phase-dot-3 { top: 50%; }
  .phase-dot-4 { top: 66%; }
  .phase-dot-5 { top: 82%; }

  /* Lit-State: Dot leuchtet ab phase.fadeIn[0] und bleibt lit für
     den Rest der Section. Kein passed/active Unterschied — die
     gefadete Phasen-Logik braucht keine "current" Markierung. */
  .phase-dot.dot-lit {
    background: rgba(245, 158, 11, 1);
    border-color: rgba(245, 158, 11, 1);
    box-shadow:
      0 0 12px rgba(245, 158, 11, 0.7),
      0 0 24px rgba(245, 158, 11, 0.35);
    transform: translateX(-50%) scale(1.2);
  }

  /* === Phasen — Two-at-a-time Crossfade ===
     Container ist absolut auf Höhe Dot 3 zentriert. Phases teilen
     sich grid-row 1 — alle übereinander gestapelt, Container-Höhe
     wird von der höchsten Phase bestimmt. Sichtbarkeit kommt aus
     --phase-opacity (JS-controlled per Phase). Odd-Phasen (1/3/5)
     teilen sich die linke Position, Even-Phasen (2/4) die rechte —
     beim Crossfade kreuzt sich nichts. */
  .phases-container {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    pointer-events: none;
  }

  .phase {
    grid-column: 1;
    grid-row: 1;
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    align-items: center;
    pointer-events: none;
    opacity: var(--phase-opacity, 0);
    transition: opacity 80ms linear;
    will-change: opacity;
  }

  /* phase-side: ein Block für Label + Title + Body.
     Hält den Lese-Flow zusammen statt Label und Content gegenüber-
     liegend zu verteilen. Vertikal gestapelt, horizontal eine Seite. */
  .phase-side {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
    align-self: center;
  }

  /* Alternation Desktop only.
     Odd (Phase 1/3/5): phase-side LINKS (column 1), rechtsbündig.
     Even (Phase 2/4):  phase-side RECHTS (column 3), linksbündig.
     Same-Side Phasen (1↔3↔5, 2↔4) crossfaden an gleicher Position. */
  @media (min-width: 1024px) {
    .phase:nth-child(odd) .phase-side {
      grid-column: 1;
      justify-self: end;
      text-align: right;
      padding-right: 32px;
    }
    .phase:nth-child(even) .phase-side {
      grid-column: 3;
      justify-self: start;
      text-align: left;
      padding-left: 32px;
    }
  }

  /* PHASE_XX Decoration — Brand-Amber. Glow ist statisch (nicht
     mehr active-state-driven), weil Two-at-a-time keinen "current"
     Singularitäts-State mehr hat. */
  .phase-label {
    font-family: 'Aileron', 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: rgba(245, 158, 11, 0.95);
    letter-spacing: -0.03em;
    line-height: 1;
    text-shadow:
      0 0 24px rgba(245, 158, 11, 0.7),
      0 0 60px rgba(245, 158, 11, 0.4),
      0 0 120px rgba(245, 158, 11, 0.2);
    margin: 0;
  }

  .phase-title {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: #f5f5f4;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .phase-body {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(0.9rem, 1.1vw, 1rem);
    color: rgba(245, 245, 244, 0.75);
    line-height: 1.55;
    margin: 0;
  }

  .phase-body a {
    color: rgba(245, 158, 11, 0.95);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 158, 11, 0.4);
    padding-bottom: 1px;
    transition: border-color 200ms ease;
  }

  .phase-body a:hover,
  .phase-body a:focus-visible {
    border-color: rgba(245, 158, 11, 1);
  }

  /* === ScrollCue (grid-row 3, am unteren Rand) — eigene Visibility,
     getrieben vom Settled-Progress. 32px padding-top sichert
     erkennbare Distanz zum letzten Dot/Linien-Ende. */
  .section-4-scrollcue-wrap {
    --cue-progress: 0;
    grid-row: 3;
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 32px;
    opacity: var(--cue-progress);
    transform: translateY(calc((1 - var(--cue-progress)) * 8px));
    transition: opacity 300ms ease, transform 300ms ease;
  }

  /* Override Anchor-Defaults von ScrollCue: in Section 4 fließt der
     Cue im Grid-Row, nicht absolute am Section-Bottom. */
  .section-4 .scroll-cue-anchor {
    position: static;
    bottom: auto;
  }

  /* === Mobile (< 1024px): einseitiges Layout, Linie links ===
     Auf Mobile gibt's keinen Two-at-a-Time Crossfade — JS zeigt
     genau eine Phase per progress, weil sich zwei überlagerte
     linksbündige Phasen unleserlich übereinander legen würden. */
  @media (max-width: 1024px) {
    .timeline-line {
      left: 16px;
      transform: none;
    }

    .phase-dot {
      left: 16px;
      width: 10px;
      height: 10px;
    }

    .phase-dot.dot-lit {
      transform: translateX(-50%) scale(1.2);
    }

    .phase {
      grid-template-columns: 32px 1fr;
    }

    .phase:nth-child(odd) .phase-side,
    .phase:nth-child(even) .phase-side {
      grid-column: 2;
      justify-self: start;
      text-align: left;
      padding: 0 0 0 24px;
    }

    .phase-label {
      font-size: clamp(1.5rem, 8vw, 2.5rem);
    }
  }

  /* Reduced-motion: Settled-State zeigen — Phase 4 + Phase 5 (das
     finale Two-at-a-time Paar) sichtbar, alle Dots lit, Linie voll
     bis Dot 5 (90%). Andere Phasen bleiben unsichtbar (kein Stacken
     unleserlicher Übereinanderlagen). */
  @media (prefers-reduced-motion: reduce) {
    .section-4-header {
      --header-progress: 1 !important;
      transform: none !important;
    }
    .phase {
      transition: none !important;
    }
    .phase.phase-1,
    .phase.phase-2,
    .phase.phase-3 {
      opacity: 0 !important;
    }
    .phase.phase-4,
    .phase.phase-5 {
      opacity: 1 !important;
    }
    .phase-dot {
      background: rgba(245, 158, 11, 1) !important;
      border-color: rgba(245, 158, 11, 1) !important;
      box-shadow: 0 0 8px rgba(245, 158, 11, 0.5) !important;
      transition: none !important;
    }
    .line-progress {
      stroke-dashoffset: 0 !important;
    }
    .section-4-scrollcue-wrap {
      --cue-progress: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  const section = document.querySelector('.section-4');
  const header = section ? section.querySelector('.section-4-header') : null;
  const phases = section
    ? Array.from(section.querySelectorAll('.phase'))
    : [];
  const dots = section
    ? Array.from(section.querySelectorAll('.phase-dot'))
    : [];
  const lineProgress = section
    ? section.querySelector('.line-progress')
    : null;
  const cueWrap = section
    ? section.querySelector('.section-4-scrollcue-wrap')
    : null;
  const video = section ? section.querySelector('.section-4-video') : null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduceMotion && video) {
    try { video.pause(); } catch (e) {}
  }

  if (
    section && header && phases.length === 5 && dots.length === 5 &&
    lineProgress && cueWrap
  ) {
    // Two-at-a-Time Sequence — pro Phase eigener Lifecycle:
    //   fadeIn  [start,end] — opacity 0 → 1
    //   fadeOut [start,end] — opacity 1 → 0  (null = bleibt sichtbar)
    // Same-Side Sequencing: Phase X fadeOut.end <= Phase X+2 fadeIn.start,
    // damit auf der gleichen Seite NIE zwei Phasen gleichzeitig sichtbar
    // sind. Cross-Side (Phase X ↔ X+1) darf parallel laufen — die Phasen
    // sitzen auf verschiedenen Seiten, kein Overlap.
    const phasesConfig = [
      { fadeIn: [0.10, 0.16], fadeOut: [0.24, 0.30] },
      { fadeIn: [0.20, 0.26], fadeOut: [0.39, 0.45] },
      { fadeIn: [0.30, 0.36], fadeOut: [0.49, 0.55] },
      { fadeIn: [0.45, 0.52], fadeOut: null },
      { fadeIn: [0.55, 0.62], fadeOut: null },
    ];
    // Linien-Position pro Dot (0..100, line-relativ). Linie spannt
    // jetzt 18%-82% des Wraps; Dot 1 = Linien-Start (0), Dot 5 =
    // Linien-Ende (100). dashoffset = 100 - linePos.
    const linePositions = [0, 25, 50, 75, 100];
    // Mobile-Slices: 5 gleich große Phasen-Slots nach dem Lead-In
    // (0.10), letzte Phase bleibt im Settled-Tail.
    const mobileBoundaries = [0.10, 0.27, 0.44, 0.61, 0.78];
    const HEADER_END = 0.06;
    const SETTLED_AT = 0.92;
    const CUE_RANGE = 0.06;
    const desktopMQ = window.matchMedia('(min-width: 1024px)');

    function clamp01(v) {
      return v < 0 ? 0 : v > 1 ? 1 : v;
    }

    function getScrollProgress() {
      const rect = section.getBoundingClientRect();
      const total = section.offsetHeight - window.innerHeight;
      if (total <= 0) return 0;
      return clamp01(-rect.top / total);
    }

    function phaseOpacity(phase, progress) {
      if (progress < phase.fadeIn[0]) return 0;
      if (progress < phase.fadeIn[1]) {
        return (progress - phase.fadeIn[0]) /
               (phase.fadeIn[1] - phase.fadeIn[0]);
      }
      if (!phase.fadeOut || progress < phase.fadeOut[0]) return 1;
      if (progress < phase.fadeOut[1]) {
        return 1 - (progress - phase.fadeOut[0]) /
                   (phase.fadeOut[1] - phase.fadeOut[0]);
      }
      return 0;
    }

    function determineActivePhaseMobile(progress) {
      if (progress < mobileBoundaries[0]) return -1;
      for (let i = mobileBoundaries.length - 1; i >= 0; i--) {
        if (progress >= mobileBoundaries[i]) return i;
      }
      return -1;
    }

    function update() {
      if (reduceMotion) {
        header.style.setProperty('--header-progress', '1');
        for (let i = 0; i < phases.length; i++) {
          // Settled: Phase 4 + 5 sichtbar (finales Two-at-a-time Paar)
          phases[i].style.setProperty(
            '--phase-opacity',
            i === 3 || i === 4 ? '1' : '0'
          );
          phases[i].style.pointerEvents = i === 3 || i === 4 ? 'auto' : 'none';
          dots[i].classList.add('dot-lit');
        }
        lineProgress.style.strokeDashoffset = String(100 - linePositions[4]);
        cueWrap.style.setProperty('--cue-progress', '1');
        return;
      }

      const progress = getScrollProgress();
      const isDesktop = desktopMQ.matches;

      // Header
      const headerP = clamp01(progress / HEADER_END);
      header.style.setProperty('--header-progress', String(headerP));

      // Phase-Opacity: Desktop crossfade, Mobile hard switch
      if (isDesktop) {
        for (let i = 0; i < phases.length; i++) {
          const op = phaseOpacity(phasesConfig[i], progress);
          phases[i].style.setProperty('--phase-opacity', op.toFixed(3));
          phases[i].style.pointerEvents = op > 0.5 ? 'auto' : 'none';
        }
      } else {
        const activeIdx = determineActivePhaseMobile(progress);
        for (let i = 0; i < phases.length; i++) {
          const isActive = i === activeIdx;
          phases[i].style.setProperty('--phase-opacity', isActive ? '1' : '0');
          phases[i].style.pointerEvents = isActive ? 'auto' : 'none';
        }
      }

      // Dots: lit ab eigenem Trigger, bleiben für den Rest lit.
      // Linie zieht zum letzten lit-Dot.
      let lastLitIdx = -1;
      if (isDesktop) {
        for (let i = 0; i < phases.length; i++) {
          const lit = progress >= phasesConfig[i].fadeIn[0];
          dots[i].classList.toggle('dot-lit', lit);
          if (lit) lastLitIdx = i;
        }
      } else {
        for (let i = 0; i < phases.length; i++) {
          const lit = progress >= mobileBoundaries[i];
          dots[i].classList.toggle('dot-lit', lit);
          if (lit) lastLitIdx = i;
        }
      }

      const linePos = lastLitIdx >= 0 ? linePositions[lastLitIdx] : 0;
      lineProgress.style.strokeDashoffset = String(100 - linePos);

      // ScrollCue im Settled-Tail
      const cueP = clamp01((progress - SETTLED_AT) / CUE_RANGE);
      cueWrap.style.setProperty('--cue-progress', String(cueP));
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    }

    let resizeTimer = 0;
    function onResize() {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(update, 120);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    update();
  }
</script>
