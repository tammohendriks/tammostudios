---
import { SECTION5 } from '../../lib/constants';

const { eyebrow, headline, subtext, primaryCta, secondaryEmail, footer } = SECTION5;

// Cosmic Background Layers — visuelle Klammer zu Section 1.
// Weniger Partikel (12 vs 18) und langsamere Drift-Tempi (30–55s),
// damit Closing-Section ruhiger wirkt als Hero. delta-x/y in vw/vh
// statt %, damit translate() Viewport-Distanz fährt (% wäre element-
// relativ und damit für 2–4px Punkte praktisch null).
const PARTICLE_COUNT = 12;
const particles = Array.from({ length: PARTICLE_COUNT }, () => {
  const startX = Math.random() * 100;
  const startY = Math.random() * 100;
  const endX = Math.random() * 100;
  const endY = Math.random() * 100;
  return {
    startX,
    startY,
    deltaX: endX - startX,
    deltaY: endY - startY,
    duration: 30 + Math.random() * 25,
    delay: -Math.random() * 50,
    size: 2 + Math.random() * 2,
    opacity: 0.4 + Math.random() * 0.5,
  };
});
---

<section class="section-5">
  <div class="section-5-cosmos" aria-hidden="true">
    <div class="s5-aurora s5-aurora-1"></div>
    <div class="s5-aurora s5-aurora-2"></div>
    <div class="s5-particles">
      {particles.map((p) => (
        <span
          class="s5-particle"
          style={`--start-x: ${p.startX}%; --start-y: ${p.startY}%; --delta-x: ${p.deltaX}vw; --delta-y: ${p.deltaY}vh; --duration: ${p.duration}s; --delay: ${p.delay}s; --size: ${p.size}px; --opacity: ${p.opacity};`}
        ></span>
      ))}
    </div>
  </div>

  <div class="section-5-bg" aria-hidden="true"></div>

  <div class="closing">
    <p class="closing-eyebrow reveal">{eyebrow}</p>

    <div class="logo-frame reveal">
      <img src="/logos/logo-full.png" alt="Tammo Studios" />
    </div>

    <h2 class="closing-headline reveal">{headline}</h2>

    <p class="closing-sub reveal">{subtext}</p>

    <a class="cta-orbital closing-cta reveal" href={primaryCta.href}>
      <span class="cta-label">{primaryCta.label}</span>
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </a>

    <p class="closing-secondary reveal">
      Oder direkt:
      {' '}
      <a href={`mailto:${secondaryEmail}`}>{secondaryEmail}</a>
    </p>
  </div>

  <footer class="site-footer">
    <div class="footer-row">
      <span class="footer-brand">{footer.brand}</span>
      <nav class="footer-nav" aria-label="Hauptnavigation">
        {footer.navLinks.map((link, i) => (
          <>
            {i > 0 && <span aria-hidden="true">·</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </nav>
    </div>
    <div class="footer-row footer-row-legal">
      <span class="footer-copy">{footer.copyright}</span>
      <nav class="footer-legal" aria-label="Rechtliches">
        {footer.legalLinks.map((link, i) => (
          <>
            {i > 0 && <span aria-hidden="true">·</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </nav>
    </div>
  </footer>
</section>

<style>
  /* Desktop: min-height 100dvh — Section ist mindestens viewport-hoch,
     darf aber wachsen wenn Content mehr braucht. Garantiert dass der
     Footer auch auf knappen Höhen sichtbar bleibt (vorheriges hartes
     max-height + overflow:hidden hat den Footer auf 1080p geclippt).
     Mobile übernimmt den harten 100dvh-Cap im @media-Block weiter unten. */
  .section-5 {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: #050507;
    padding: 100px 40px 28px;
  }

  /* Mobile-Override: hartes 100dvh, kein Scroll-Past. Closing-Block
     + Footer müssen zusammen reinpassen — ultra-compact-Variante
     für sehr kurze Viewports liegt weiter unten. */
  @media (max-width: 768px) {
    .section-5 {
      height: 100dvh;
      max-height: 100dvh;
      overflow: hidden;
      padding: 90px 16px 16px;
    }

    .closing {
      gap: 16px;
      max-width: 100%;
    }

    .closing-eyebrow { font-size: 0.65rem; }
    .closing-headline { font-size: 1.45rem; }
    .closing-sub { font-size: 0.85rem; max-width: 290px; }
    .closing-cta { padding: 12px 26px; font-size: 0.95rem; }
    .closing-secondary { font-size: 0.78rem; }
  }

  /* Dezenter warmer Glow hinter dem Logo — sitzt über den Cosmos-
     Layern, unter dem Content. */
  .section-5-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(
      ellipse at 50% 35%,
      rgba(245, 158, 11, 0.05) 0%,
      rgba(245, 158, 11, 0.02) 30%,
      rgba(245, 158, 11, 0) 60%
    );
  }

  /* === Cosmic Background — visuelle Klammer zu Section 1.
     Aurora-Blobs driften langsam, Partikel floaten diagonal.
     Deutlich ruhiger als Section 1 (weniger Partikel, längere
     Tempi), damit Closing nicht hektisch wirkt. */
  .section-5-cosmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .s5-aurora {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .s5-aurora-1 {
    width: 60vw;
    height: 60vw;
    top: 25%;
    left: 20%;
    background: radial-gradient(circle,
      rgba(245, 158, 11, 0.15) 0%,
      rgba(245, 158, 11, 0.06) 40%,
      transparent 70%);
    animation: s5-aurora-drift-1 28s ease-in-out infinite;
  }

  .s5-aurora-2 {
    width: 50vw;
    height: 50vw;
    bottom: 30%;
    right: 25%;
    background: radial-gradient(circle,
      rgba(252, 211, 77, 0.10) 0%,
      rgba(252, 211, 77, 0.04) 40%,
      transparent 70%);
    animation: s5-aurora-drift-2 36s ease-in-out infinite;
  }

  @keyframes s5-aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(6vw, -4vh) scale(1.1); }
    66%      { transform: translate(-5vw, 5vh) scale(0.95); }
  }

  @keyframes s5-aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(0.95); }
    50%      { transform: translate(-8vw, 4vh) scale(1.1); }
  }

  .s5-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .s5-particle {
    position: absolute;
    top: var(--start-y);
    left: var(--start-x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: rgba(245, 158, 11, var(--opacity));
    box-shadow:
      0 0 6px rgba(245, 158, 11, 0.6),
      0 0 12px rgba(252, 211, 77, 0.3);
    animation: s5-particle-drift var(--duration) linear infinite;
    animation-delay: var(--delay);
    will-change: transform, opacity;
  }

  @keyframes s5-particle-drift {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    8%   { opacity: var(--opacity); }
    92%  { opacity: var(--opacity); }
    100% {
      transform: translate(var(--delta-x), var(--delta-y));
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .s5-particle:nth-child(n+8) { display: none; }
    .s5-aurora { filter: blur(60px); }
  }

  .closing {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .closing-eyebrow {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    color: rgba(245, 158, 11, 0.7);
    text-transform: uppercase;
    margin: 0;
  }

  /* Runder Logo-Frame als organisch lebendiges Lichtspiel.
     Drei überlagerte Animations-Layer mit nicht-synchronen Tempi
     (4s / 14s / 5.5s) — das Auge nimmt's als "lebendig" wahr,
     weil sich nichts exakt wiederholt.

     Layer 1: stärkerer Breath-Pulse via box-shadow (4s).
     Layer 2: ::before — rotierender Conic-Gradient (Leuchtturm, 14s).
     Layer 3: ::after — innerer Highlight-Reflex (Glas-Shimmer, 5.5s). */
  .logo-frame {
    position: relative;
    width: 220px;
    height: 220px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    border: 1px solid rgba(245, 158, 11, 0.3);
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    box-shadow:
      0 0 20px rgba(245, 158, 11, 0.15),
      0 0 50px rgba(245, 158, 11, 0.08),
      0 0 90px rgba(245, 158, 11, 0.04),
      inset 0 0 20px rgba(245, 158, 11, 0.06);
    animation: logo-frame-breath 4s ease-in-out infinite;
  }

  /* Leuchtturm-Schein: rotiert hinter dem Frame und blitzt nur
     dort raus, wo er über die Frame-Kante hinaussteht. */
  .logo-frame::before {
    content: '';
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      rgba(245, 158, 11, 0)     0%,
      rgba(245, 158, 11, 0.28) 20%,
      rgba(245, 158, 11, 0)    40%,
      rgba(245, 158, 11, 0)    60%,
      rgba(245, 158, 11, 0.28) 80%,
      rgba(245, 158, 11, 0)   100%
    );
    filter: blur(30px);
    z-index: -1;
    pointer-events: none;
    animation: frame-orbit 14s linear infinite;
  }

  /* Glas-Reflex: kleiner heller Punkt links-oben pulsiert. */
  .logo-frame::after {
    content: '';
    position: absolute;
    top: 8%;
    left: 20%;
    width: 30%;
    height: 30%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 220, 130, 0.35) 0%,
      rgba(255, 220, 130, 0) 70%
    );
    filter: blur(8px);
    z-index: 1;
    pointer-events: none;
    animation: highlight-pulse 5.5s ease-in-out infinite;
  }

  .logo-frame img {
    max-width: 70%;
    max-height: 70%;
    object-fit: contain;
  }

  @keyframes logo-frame-breath {
    0%, 100% {
      box-shadow:
        0 0 20px rgba(245, 158, 11, 0.15),
        0 0 50px rgba(245, 158, 11, 0.08),
        0 0 90px rgba(245, 158, 11, 0.04),
        inset 0 0 20px rgba(245, 158, 11, 0.06);
    }
    50% {
      box-shadow:
        0 0 40px rgba(245, 158, 11, 0.32),
        0 0 90px rgba(245, 158, 11, 0.18),
        0 0 150px rgba(245, 158, 11, 0.08),
        inset 0 0 35px rgba(245, 158, 11, 0.12);
    }
  }

  @keyframes frame-orbit {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes highlight-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%      { opacity: 0.9; transform: scale(1.1); }
  }

  @media (max-width: 768px) {
    .logo-frame {
      width: 170px;
      height: 170px;
      aspect-ratio: 1 / 1;
    }
  }

  /* Compression-Stufe für sehr kleine Mobiles (kürzer als 700px,
     z.B. iPhone SE im Hochformat). Ohne diese Stufe würden Headline
     + Logo + Footer am Footer-Bereich ausfransen. */
  @media (max-width: 768px) and (max-height: 700px) {
    .section-5 {
      padding: 70px 16px 12px;
    }
    .closing {
      gap: 10px;
    }
    .logo-frame {
      width: 140px;
      height: 140px;
    }
    .closing-headline {
      font-size: 1.25rem;
    }
    .closing-sub {
      font-size: 0.78rem;
    }
  }

  /* Compression-Stufe für niedrige Desktop-Viewports (~13"-Laptops,
     800px Höhe). Ohne diese Stufe würde der Footer aus dem 100dvh-
     Viewport gedrückt. */
  @media (min-width: 769px) and (max-height: 800px) {
    .section-5 {
      padding: 80px 40px 20px;
    }
    .closing {
      gap: 14px;
    }
    .logo-frame {
      width: 180px;
      height: 180px;
    }
    .closing-headline {
      font-size: 1.55rem;
    }
    .closing-sub {
      font-size: 0.9rem;
    }
  }

  .closing-headline {
    font-family: 'Aileron', 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    margin: 8px 0 0;
    line-height: 1.1;
  }

  .closing-sub {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    color: rgba(245, 245, 244, 0.7);
    max-width: 440px;
    line-height: 1.55;
    margin: 0;
  }

  /* Section-5-spezifische Größen-Adjustments für den globalen
     .cta-orbital — Closing-CTA darf etwas mehr Präsenz haben als
     der kompakte TopBar-Button, aber nicht so groß dass sie den
     Footer aus dem Viewport drückt. */
  .closing-cta {
    margin-top: 8px;
    padding: 12px 28px;
    font-size: 0.98rem;
  }

  .closing-secondary {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(245, 245, 244, 0.6);
    margin: 4px 0 0;
  }

  .closing-secondary a {
    color: rgba(245, 158, 11, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    padding-bottom: 1px;
    transition: border-color 200ms ease, color 200ms ease;
  }

  .closing-secondary a:hover,
  .closing-secondary a:focus-visible {
    color: rgba(245, 158, 11, 1);
    border-bottom-color: rgba(245, 158, 11, 0.7);
    outline: none;
  }

  /* Footer am unteren Rand der Section — margin-top:auto drückt
     ihn nach unten innerhalb der flex-Spalte. flex-shrink:0 stellt
     sicher, dass er bei knappem Platz nicht zusammenfällt. */
  .site-footer {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 24px;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.78rem;
  }

  .footer-brand {
    color: rgba(245, 245, 244, 0.7);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .footer-copy {
    color: rgba(245, 245, 244, 0.5);
  }

  .footer-nav,
  .footer-legal {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-nav a,
  .footer-legal a {
    color: rgba(245, 245, 244, 0.7);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-nav a:hover,
  .footer-nav a:focus-visible,
  .footer-legal a:hover,
  .footer-legal a:focus-visible {
    color: rgba(245, 158, 11, 0.95);
    outline: none;
  }

  .footer-row-legal {
    color: rgba(245, 245, 244, 0.4);
    font-size: 0.72rem;
  }

  @media (max-width: 768px) {
    .site-footer {
      padding-top: 16px;
    }

    .footer-row {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: 4px 12px;
      font-size: 0.65rem;
    }

    .footer-row-legal {
      font-size: 0.6rem;
      opacity: 0.7;
    }
  }

  /* Reveal-Animation: Stagger-Fade beim Eintritt in den Viewport.
     IntersectionObserver triggert .reveal-in einmal pro Element. */
  .reveal {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 700ms ease-out, transform 700ms ease-out;
  }

  .reveal.reveal-in {
    opacity: 1;
    transform: translateY(0);
  }

  .closing-eyebrow.reveal   { transition-delay: 0ms; }
  .logo-frame.reveal        { transition-delay: 100ms; }
  .closing-headline.reveal  { transition-delay: 300ms; }
  .closing-sub.reveal       { transition-delay: 450ms; }
  .closing-cta.reveal       { transition-delay: 600ms; }
  .closing-secondary.reveal { transition-delay: 750ms; }
  /* Footer wird nicht mehr gerevealed — IntersectionObserver
     Bottom-rootMargin ließ ihn opacity:0 stuck, weil der unten
     gepinnte Footer die Threshold-Box nie überquert. Statt das
     Observer-Setup zu verbiegen ist Footer jetzt always visible. */

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .logo-frame,
    .logo-frame::before,
    .logo-frame::after {
      animation: none !important;
    }
    .logo-frame::before {
      opacity: 0.3;
    }
    .logo-frame::after {
      opacity: 0.4;
    }
  }
</style>

<script>
  const section = document.querySelector('.section-5');
  if (section) {
    const revealEls = section.querySelectorAll('.reveal');
    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (reduceMotion) {
      revealEls.forEach((el) => el.classList.add('reveal-in'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-in');
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.15,
          rootMargin: '0px 0px -10% 0px',
        }
      );
      revealEls.forEach((el) => observer.observe(el));
    }
  }
</script>
