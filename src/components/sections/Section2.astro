---
import { SECTION2 } from '../../lib/constants';
import AnimatedWordmark from '../AnimatedWordmark.astro';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-2">
  <div class="ambient-aurora" aria-hidden="true">
    <div class="aurora-layer aurora-1"></div>
    <div class="aurora-layer aurora-2"></div>
    <div class="aurora-layer aurora-3"></div>
  </div>

  <div class="section-2-sticky">
    <div class="wordmark-spotlight" aria-hidden="true"></div>

    <div class="content">
      <AnimatedWordmark />

      <div class="headline-wrap">
        <svg
          class="headline-circle"
          viewBox="0 0 800 200"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <ellipse
            cx="400"
            cy="100"
            rx="380"
            ry="80"
            fill="none"
            stroke="rgba(245, 158, 11, 0.7)"
            stroke-width="1.5"
            pathLength="100"
            stroke-dasharray="100"
            stroke-dashoffset="100"
          />
        </svg>
        <h3 class="boom-headline">{SECTION2.boomHeadline}</h3>
      </div>
    </div>

    <ScrollCue />
  </div>
</section>

<style>
  .section-2 {
    position: relative;
    min-height: 300vh;
    background: linear-gradient(to bottom, #000 0%, #0a0a0c 100%);
    /* KEIN overflow: hidden — bricht position: sticky des inneren Containers. */
  }

  @media (max-width: 768px) {
    .section-2 {
      min-height: 220vh;
    }
  }

  .section-2-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
  }

  /* Content zentriert den linksbündigen Wordmark-Block horizontal. */
  .content {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 80px;
    width: 100%;
  }

  @media (max-width: 767px) {
    .content {
      gap: 48px;
    }
  }

  .headline-wrap {
    position: relative;
    display: inline-block;
    padding: 32px 48px;
  }

  @media (max-width: 767px) {
    .headline-wrap {
      padding: 24px 28px;
    }
  }

  .headline-circle {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  .headline-circle ellipse {
    transition: stroke-dashoffset 80ms linear;
    filter:
      drop-shadow(0 0 16px rgba(245, 158, 11, 0.6))
      drop-shadow(0 0 32px rgba(245, 158, 11, 0.3));
  }

  .boom-headline {
    --headline-progress: 0;
    position: relative;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0;

    opacity: var(--headline-progress);
    transform: scale(calc(0.92 + var(--headline-progress) * 0.08));
    filter: blur(calc((1 - var(--headline-progress)) * 4px));
    text-shadow:
      0 0 calc(var(--headline-progress) * 30px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.7)),
      0 0 calc(var(--headline-progress) * 80px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.4)),
      0 0 calc(var(--headline-progress) * 160px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.2));
  }

  /* === Ambient Aurora === */
  /* Pro-Layer-Multiplikatoren <1: dezenter als vorher, gibt dem
     Spotlight Bühne. */
  .ambient-aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    --aurora-intensity: 0;
  }

  .aurora-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    mix-blend-mode: screen;
    transition: opacity 200ms linear;
    will-change: transform, opacity;
  }

  .aurora-1 {
    width: 70vw;
    height: 70vw;
    top: 20%;
    left: 15%;
    opacity: calc(var(--aurora-intensity) * 0.6);
    background: radial-gradient(circle,
      rgba(245, 158, 11, 0.55) 0%,
      rgba(245, 158, 11, 0.25) 30%,
      rgba(245, 158, 11, 0)    65%);
    animation: aurora-drift-1 22s ease-in-out infinite;
  }

  .aurora-2 {
    width: 55vw;
    height: 55vw;
    top: 30%;
    right: 10%;
    opacity: calc(var(--aurora-intensity) * 0.5);
    background: radial-gradient(circle,
      rgba(252, 211, 77, 0.45) 0%,
      rgba(252, 211, 77, 0.18) 35%,
      rgba(252, 211, 77, 0)    70%);
    animation: aurora-drift-2 28s ease-in-out infinite;
  }

  .aurora-3 {
    width: 60vw;
    height: 60vw;
    bottom: 10%;
    left: 35%;
    opacity: calc(var(--aurora-intensity) * 0.55);
    background: radial-gradient(circle,
      rgba(217, 119, 6, 0.40) 0%,
      rgba(217, 119, 6, 0.15) 40%,
      rgba(217, 119, 6, 0)    75%);
    animation: aurora-drift-3 34s ease-in-out infinite;
  }

  @keyframes aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(8vw, -5vh) scale(1.15); }
    66%      { transform: translate(-6vw, 8vh) scale(0.9); }
  }

  @keyframes aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-10vw, 6vh) scale(1.2); }
  }

  @keyframes aurora-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(0.95); }
    25%      { transform: translate(5vw, -8vh) scale(1.1); }
    75%      { transform: translate(-7vw, -4vh) scale(1.05); }
  }

  /* === Wordmark Spotlight ===
     Sitzt INSIDE des sticky Containers, damit `top` in % an 100dvh
     hängt → Wert 80% / 35% bedeutet 80vh / 35vh des sichtbaren
     Viewports während die Sektion gepinnt ist. */
  .wordmark-spotlight {
    --spotlight-y: 80%;
    --spotlight-intensity: 0;
    position: absolute;
    left: 50%;
    width: 90vw;
    max-width: 1200px;
    aspect-ratio: 16 / 9;
    pointer-events: none;
    mix-blend-mode: screen;
    z-index: 1;
    top: var(--spotlight-y);
    transform: translate(-50%, -50%);
    opacity: var(--spotlight-intensity);
    /* Zentrum bewusst gedimmt: rahmt den Wordmark warm ein, ohne ihn
       auszubleichen. Letterforms bleiben definiert gegen den Glow. */
    background: radial-gradient(
      ellipse at center,
      rgba(252, 211, 77, 0.32) 0%,
      rgba(245, 158, 11, 0.22) 22%,
      rgba(217, 119, 6, 0.12)  45%,
      rgba(120, 53,  15, 0.04) 70%,
      rgba(0,   0,   0,   0)   88%
    );
    filter: blur(60px);
    transition: top 200ms linear, opacity 200ms linear;
    will-change: top, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .boom-headline {
      --headline-progress: 1 !important;
    }
    .headline-circle ellipse {
      stroke-dashoffset: 0 !important;
      transition: none;
    }
    .aurora-layer {
      animation: none !important;
    }
    .ambient-aurora {
      --aurora-intensity: 0.5 !important;
    }
    .wordmark-spotlight {
      --spotlight-y: 28% !important;
      --spotlight-intensity: 1 !important;
      transition: none !important;
    }
  }
</style>

<script>
  const section = document.querySelector('.section-2');
  const stickyChars = section ? Array.from(section.querySelectorAll('.char')) : [];
  const headline = section ? section.querySelector('.boom-headline') : null;
  const ellipse = section ? section.querySelector('.headline-circle ellipse') : null;
  const aurora = section ? section.querySelector('.ambient-aurora') : null;
  const wordmark = section ? section.querySelector('.wordmark') : null;
  const spotlight = section ? section.querySelector('.wordmark-spotlight') : null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (
    section && stickyChars.length && headline && ellipse &&
    aurora && wordmark && spotlight
  ) {
    const stepsForChars = stickyChars.length;
    const headlineStartStep = stepsForChars + 2;
    const headlineEndStep = headlineStartStep + 2;
    const circleStartStep = headlineEndStep;
    const circleEndStep = circleStartStep + 4;
    const totalSteps = circleEndStep;

    // Animation belegt nur die ersten 75% des Section-Scrolls. Die letzten
    // 25% sind Settled-State: Spotlight stabil, Wordmark-Glow voll, Aurora
    // weiter dezent driftend.
    const ANIMATION_RANGE = 0.75;
    const SETTLE_START = ANIMATION_RANGE;
    // Spotlight erreicht seine Endposition leicht nach Animationsende,
    // damit er beim Übergang in den Settled-State sauber "ankommt".
    const SPOTLIGHT_END = 0.85;
    const SPOTLIGHT_FROM_Y = 80;
    const SPOTLIGHT_TO_Y = 28;

    function clamp01(v) {
      return v < 0 ? 0 : v > 1 ? 1 : v;
    }

    function rangeProgress(progress, startStep, endStep) {
      const a = startStep / totalSteps;
      const b = endStep / totalSteps;
      return clamp01((progress - a) / (b - a));
    }

    function getScrollProgress() {
      const rect = section.getBoundingClientRect();
      const totalScrollDistance = section.offsetHeight - window.innerHeight;
      if (totalScrollDistance <= 0) return 0;
      return clamp01(-rect.top / totalScrollDistance);
    }

    function update() {
      if (reduceMotion) {
        for (const char of stickyChars) char.style.setProperty('--char-progress', '1');
        headline.style.setProperty('--headline-progress', '1');
        ellipse.style.strokeDashoffset = '0';
        aurora.style.setProperty('--aurora-intensity', '0.5');
        wordmark.style.setProperty('--settle-progress', '1');
        spotlight.style.setProperty('--spotlight-y', '28%');
        spotlight.style.setProperty('--spotlight-intensity', '1');
        return;
      }

      const rawProgress = getScrollProgress();
      const progress = Math.min(1, rawProgress / ANIMATION_RANGE);

      for (let i = 0; i < stickyChars.length; i++) {
        const cp = rangeProgress(progress, i, i + 1);
        stickyChars[i].style.setProperty('--char-progress', String(cp));
      }

      const hp = rangeProgress(progress, headlineStartStep, headlineEndStep);
      headline.style.setProperty('--headline-progress', String(hp));

      const ep = rangeProgress(progress, circleStartStep, circleEndStep);
      ellipse.style.strokeDashoffset = String(100 * (1 - ep));

      aurora.style.setProperty('--aurora-intensity', String(progress));

      // Settled-State Glow auf der Wordmark, scroll-driven von 0 → 1
      // zwischen 75% und 100% rawProgress.
      const settleProgress = clamp01(
        (rawProgress - SETTLE_START) / (1 - SETTLE_START),
      );
      wordmark.style.setProperty('--settle-progress', String(settleProgress));

      // Rising Spotlight: steigt im Viewport von 80% (unten) auf 35%
      // (oberhalb Wordmark), Intensität 0 → 1.
      const spotlightProgress = Math.min(1, rawProgress / SPOTLIGHT_END);
      const spotlightY =
        SPOTLIGHT_FROM_Y - spotlightProgress * (SPOTLIGHT_FROM_Y - SPOTLIGHT_TO_Y);
      spotlight.style.setProperty('--spotlight-y', `${spotlightY}%`);
      spotlight.style.setProperty('--spotlight-intensity', String(spotlightProgress));
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    update();
  }
</script>
