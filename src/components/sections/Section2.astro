---
import { SECTION2 } from '../../lib/constants';
import AnimatedWordmark from '../AnimatedWordmark.astro';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-2">
  <div class="content">
    <AnimatedWordmark />
    <h3 class="boom-headline">{SECTION2.boomHeadline}</h3>
  </div>

  <ScrollCue />
</section>

<style>
  .section-2 {
    position: relative;
    overflow: hidden;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    background: linear-gradient(to bottom, #000 0%, #0a0a0c 100%);
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 64px;
    width: 100%;
  }

  @media (max-width: 767px) {
    .content {
      gap: 40px;
    }
  }

  .boom-headline {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0;

    /* Initial state: unsichtbar, wartet auf .boom-visible */
    opacity: 0;
    transform: scale(0.92);
    filter: blur(4px);
  }

  .boom-headline.boom-visible {
    animation: boom-in 700ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes boom-in {
    0% {
      opacity: 0;
      transform: scale(0.92);
      filter: blur(4px);
      text-shadow: 0 0 0 rgba(245, 158, 11, 0);
    }
    50% {
      opacity: 1;
      transform: scale(1.04);
      filter: blur(0);
      text-shadow: 0 0 30px rgba(245, 158, 11, 0.4);
    }
    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
      text-shadow: 0 0 12px rgba(245, 158, 11, 0.15);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boom-headline {
      opacity: 1;
      transform: none;
      filter: none;
    }
    .boom-headline.boom-visible {
      animation-duration: 0ms;
    }
  }
</style>
