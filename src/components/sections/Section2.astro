---
import { SECTION2 } from '../../lib/constants';
import AnimatedWordmark from '../AnimatedWordmark.astro';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-2">
  <div class="section-2-sticky">
    <div class="content">
      <AnimatedWordmark />

      <div class="headline-wrap">
        <svg
          class="headline-circle"
          viewBox="0 0 800 200"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <ellipse
            cx="400"
            cy="100"
            rx="380"
            ry="80"
            fill="none"
            stroke="rgba(245, 158, 11, 0.7)"
            stroke-width="1.5"
            pathLength="100"
            stroke-dasharray="100"
            stroke-dashoffset="100"
          />
        </svg>
        <h3 class="boom-headline">{SECTION2.boomHeadline}</h3>
      </div>
    </div>

    <ScrollCue />
  </div>
</section>

<style>
  .section-2 {
    position: relative;
    min-height: 200vh;
    background: linear-gradient(to bottom, #000 0%, #0a0a0c 100%);
    /* KEIN overflow: hidden — das bricht position: sticky des inneren
       .section-2-sticky in den meisten Browsern. Der Halo-Drop-Shadow
       der Ellipse darf ruhig leicht über die Section-Grenzen ragen. */
  }

  @media (max-width: 767px) {
    .section-2 {
      /* iOS Safari sticky-Quirk: kürzere Runway, sonst springt sticky */
      min-height: 150vh;
    }
  }

  .section-2-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    /* Fallback für ältere iOS Safari, die 100vh durch URL-Bar verfälschen */
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 80px;
    width: 100%;
  }

  @media (max-width: 767px) {
    .content {
      gap: 48px;
    }
  }

  .headline-wrap {
    position: relative;
    display: inline-block;
    padding: 32px 48px;
  }

  @media (max-width: 767px) {
    .headline-wrap {
      padding: 24px 28px;
    }
  }

  .headline-circle {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  .headline-circle ellipse {
    /* JS schreibt stroke-dashoffset direkt; transition glättet die rAF-Updates. */
    transition: stroke-dashoffset 80ms linear;
    filter: drop-shadow(0 0 12px rgba(245, 158, 11, 0.5));
  }

  .boom-headline {
    --headline-progress: 0;
    position: relative;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0;

    opacity: var(--headline-progress);
    transform: scale(calc(0.92 + var(--headline-progress) * 0.08));
    filter: blur(calc((1 - var(--headline-progress)) * 4px));
    text-shadow:
      0 0 calc(var(--headline-progress) * 30px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.5)),
      0 0 calc(var(--headline-progress) * 80px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.25));
  }

  @media (prefers-reduced-motion: reduce) {
    .boom-headline {
      --headline-progress: 1 !important;
    }
    .headline-circle ellipse {
      stroke-dashoffset: 0 !important;
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector('.section-2');
  const stickyChars = section ? Array.from(section.querySelectorAll('.char')) : [];
  const headline = section ? section.querySelector('.boom-headline') : null;
  const ellipse = section ? section.querySelector('.headline-circle ellipse') : null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (section && stickyChars.length && headline && ellipse) {
    // 14 Chars + 2 Halt-Steps + Headline-Fade (2 Steps) + Circle-Draw (4 Steps)
    // Reihenfolge:
    //   0..13   → chars
    //   14..15  → kurze Pause
    //   16..17  → headline progressive in
    //   18..21  → ellipse zeichnet sich
    const stepsForChars = stickyChars.length;
    const headlineStartStep = stepsForChars + 2;
    const headlineEndStep = headlineStartStep + 2;
    const circleStartStep = headlineEndStep;
    const circleEndStep = circleStartStep + 4;
    const totalSteps = circleEndStep;

    function clamp01(v) {
      return v < 0 ? 0 : v > 1 ? 1 : v;
    }

    function rangeProgress(progress, startStep, endStep) {
      const a = startStep / totalSteps;
      const b = endStep / totalSteps;
      return clamp01((progress - a) / (b - a));
    }

    function getScrollProgress() {
      const rect = section.getBoundingClientRect();
      const totalScrollDistance = section.offsetHeight - window.innerHeight;
      if (totalScrollDistance <= 0) return 0;
      return clamp01(-rect.top / totalScrollDistance);
    }

    function update() {
      if (reduceMotion) {
        // CSS !important hat Vorrang — JS-Werte sind hier zwar gesetzt, aber
        // nicht visuell wirksam. Trotzdem konsistent halten.
        for (const char of stickyChars) char.style.setProperty('--char-progress', '1');
        headline.style.setProperty('--headline-progress', '1');
        ellipse.style.strokeDashoffset = '0';
        return;
      }

      const progress = getScrollProgress();

      for (let i = 0; i < stickyChars.length; i++) {
        const charProgress = rangeProgress(progress, i, i + 1);
        stickyChars[i].style.setProperty('--char-progress', String(charProgress));
      }

      const headlineProgress = rangeProgress(progress, headlineStartStep, headlineEndStep);
      headline.style.setProperty('--headline-progress', String(headlineProgress));

      const circleProgress = rangeProgress(progress, circleStartStep, circleEndStep);
      ellipse.style.strokeDashoffset = String(100 * (1 - circleProgress));
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    update();
  }
</script>
