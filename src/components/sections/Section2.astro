---
import { SECTION2 } from '../../lib/constants';
import AnimatedWordmark from '../AnimatedWordmark.astro';
import ScrollCue from '../ScrollCue.astro';
---

<section class="section-2">
  <div class="ambient-aurora" aria-hidden="true">
    <div class="aurora-layer aurora-1"></div>
    <div class="aurora-layer aurora-2"></div>
    <div class="aurora-layer aurora-3"></div>
  </div>

  <div class="section-2-sticky">
    <div class="wordmark-spotlight" aria-hidden="true"></div>

    <div class="content">
      <AnimatedWordmark />

      <div class="headline-wrap">
        <svg
          class="headline-circle"
          viewBox="0 0 800 200"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <ellipse
            cx="400"
            cy="100"
            rx="380"
            ry="80"
            fill="none"
            stroke="rgba(245, 158, 11, 0.7)"
            stroke-width="1.5"
            pathLength="100"
            stroke-dasharray="100"
            stroke-dashoffset="100"
          />
        </svg>
        <h3 class="boom-headline">{SECTION2.boomHeadline}</h3>
      </div>
    </div>

    <ScrollCue />
  </div>
</section>

<style>
  .section-2 {
    position: relative;
    min-height: 300vh;
    background: linear-gradient(to bottom, #000 0%, #0a0a0c 100%);
    /* KEIN overflow: hidden — bricht position: sticky des inneren Containers. */
  }

  @media (max-width: 768px) {
    .section-2 {
      min-height: 220vh;
    }
  }

  .section-2-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
  }

  @media (max-width: 768px) {
    .section-2-sticky {
      padding: 60px 16px;
    }
  }

  /* Content zentriert den linksbündigen Wordmark-Block horizontal. */
  .content {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 80px;
    width: 100%;
  }

  @media (max-width: 768px) {
    .content {
      gap: 36px;
    }
  }

  .headline-wrap {
    position: relative;
    display: inline-block;
    padding: 32px 48px;
  }

  @media (max-width: 768px) {
    .headline-wrap {
      padding: 24px 28px;
    }
    .boom-headline {
      font-size: clamp(1.5rem, 5vw, 2rem);
    }
  }

  .headline-circle {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  .headline-circle ellipse {
    transition: stroke-dashoffset 80ms linear;
    filter:
      drop-shadow(0 0 16px rgba(245, 158, 11, 0.6))
      drop-shadow(0 0 32px rgba(245, 158, 11, 0.3));
  }

  /* Harter Hidden-Default: visibility:hidden + opacity:0 + keine Filter
     stellen sicher, dass beim Section-Eintritt keine Render-Spuren von
     blur oder text-shadow durchschlagen. Erst wenn JS die Aktiv-Klasse
     `.headline-on` setzt, greifen die var-getriebenen Effekte. */
  .boom-headline {
    --headline-progress: 0;
    position: relative;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: #f5f5f4;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0;

    opacity: 0;
    visibility: hidden;
    transform: scale(0.92);
    filter: none;
    text-shadow: none;
  }

  .boom-headline.headline-on {
    visibility: visible;
    opacity: var(--headline-progress);
    transform: scale(calc(0.92 + var(--headline-progress) * 0.08));
    filter: blur(calc((1 - var(--headline-progress)) * 4px));
    text-shadow:
      0 0 calc(var(--headline-progress) * 30px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.7)),
      0 0 calc(var(--headline-progress) * 80px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.4)),
      0 0 calc(var(--headline-progress) * 160px)
        rgba(245, 158, 11, calc(var(--headline-progress) * 0.2));
  }

  /* === Ambient Aurora === */
  /* Pro-Layer-Multiplikatoren <1: dezenter als vorher, gibt dem
     Spotlight Bühne. */
  .ambient-aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    --aurora-intensity: 0;
    contain: layout style paint;
  }

  .aurora-layer {
    position: absolute;
    border-radius: 50%;
    /* 30px blur: weiter runter (war 35 / vorher 45 / ursprünglich 60).
       Visuell minimal anders, GPU-Kosten weiter unten — hilft Mobile
       deutlich. */
    filter: blur(30px);
    mix-blend-mode: screen;
    transition: opacity 200ms linear;
    will-change: transform, opacity;
    /* Layout/style/paint containment: isoliert die Aurora-Layer
       gegen Reflows / Repaints anderswo auf der Seite. */
    contain: layout style paint;
  }

  .aurora-1 {
    width: 70vw;
    height: 70vw;
    top: 20%;
    left: 15%;
    opacity: calc(var(--aurora-intensity) * 0.6);
    background: radial-gradient(circle,
      rgba(245, 158, 11, 0.55) 0%,
      rgba(245, 158, 11, 0.25) 30%,
      rgba(245, 158, 11, 0)    65%);
    animation: aurora-drift-1 22s ease-in-out infinite;
  }

  .aurora-2 {
    width: 55vw;
    height: 55vw;
    top: 30%;
    right: 10%;
    opacity: calc(var(--aurora-intensity) * 0.5);
    background: radial-gradient(circle,
      rgba(252, 211, 77, 0.45) 0%,
      rgba(252, 211, 77, 0.18) 35%,
      rgba(252, 211, 77, 0)    70%);
    animation: aurora-drift-2 28s ease-in-out infinite;
  }

  .aurora-3 {
    width: 60vw;
    height: 60vw;
    bottom: 10%;
    left: 35%;
    opacity: calc(var(--aurora-intensity) * 0.55);
    background: radial-gradient(circle,
      rgba(217, 119, 6, 0.40) 0%,
      rgba(217, 119, 6, 0.15) 40%,
      rgba(217, 119, 6, 0)    75%);
    animation: aurora-drift-3 34s ease-in-out infinite;
  }

  @keyframes aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(8vw, -5vh) scale(1.15); }
    66%      { transform: translate(-6vw, 8vh) scale(0.9); }
  }

  @keyframes aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-10vw, 6vh) scale(1.2); }
  }

  @keyframes aurora-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(0.95); }
    25%      { transform: translate(5vw, -8vh) scale(1.1); }
    75%      { transform: translate(-7vw, -4vh) scale(1.05); }
  }

  /* Mobile Performance: nur Layer 1 ist sichtbar, Layer 2 und 3
     entfallen — spart 2× blur-Operationen pro Frame. Layer 1 wird
     auf 110vmax skaliert + leicht hellere Multiplier um den
     Verlust optisch zu kompensieren. */
  @media (max-width: 768px) {
    .aurora-2,
    .aurora-3 {
      display: none;
    }
    .aurora-1 {
      width: 110vmax;
      height: 110vmax;
      opacity: calc(var(--aurora-intensity) * 0.7);
    }
  }

  /* === Wordmark Spotlight ===
     Sitzt INSIDE des sticky Containers. Vorher animierte top: var(...)
     pro Scroll-Tick die Vertikalposition — das hat einen Layout-Pass
     getriggert und CLS auf 0.74 hochgetrieben. Jetzt: top/left statisch
     auf 50%, die ganze Vertikalbewegung läuft via transform mit einer
     --spotlight-offset Variable in vh. translate wird im Compositor
     gerechnet, kein Reflow → CLS = 0. */
  .wordmark-spotlight {
    --spotlight-offset: 30vh;
    --spotlight-intensity: 0;
    position: absolute;
    top: 50%;
    left: 50%;
    width: 90vw;
    max-width: 1200px;
    aspect-ratio: 16 / 9;
    pointer-events: none;
    mix-blend-mode: screen;
    z-index: 1;
    transform: translate(-50%, calc(-50% + var(--spotlight-offset)));
    opacity: var(--spotlight-intensity);
    /* Zentrum bewusst gedimmt: rahmt den Wordmark warm ein, ohne ihn
       auszubleichen. Letterforms bleiben definiert gegen den Glow. */
    background: radial-gradient(
      ellipse at center,
      rgba(252, 211, 77, 0.32) 0%,
      rgba(245, 158, 11, 0.22) 22%,
      rgba(217, 119, 6, 0.12)  45%,
      rgba(120, 53,  15, 0.04) 70%,
      rgba(0,   0,   0,   0)   88%
    );
    /* 35px blur — bleibt etwas höher als bei Aurora, weil das
       Spotlight die fokussierte Lichtquelle ist. */
    filter: blur(35px);
    /* KEINE transition auf transform — sonst lag durch Smoothing über
       jeden Scroll-Tick. Nur opacity bekommt den weichen On/Off. */
    transition: opacity 200ms linear;
    will-change: transform, opacity;
    contain: layout style paint;
  }

  @media (prefers-reduced-motion: reduce) {
    .boom-headline {
      --headline-progress: 1 !important;
    }
    .headline-circle ellipse {
      stroke-dashoffset: 0 !important;
      transition: none;
    }
    .aurora-layer {
      animation: none !important;
    }
    .ambient-aurora {
      --aurora-intensity: 0.5 !important;
    }
    .wordmark-spotlight {
      --spotlight-offset: -22vh !important;
      --spotlight-intensity: 1 !important;
      transition: none !important;
    }
  }
</style>

<script>
  const section = document.querySelector('.section-2');
  const stickyChars = section ? Array.from(section.querySelectorAll('.char')) : [];
  const headline = section ? section.querySelector('.boom-headline') : null;
  const ellipse = section ? section.querySelector('.headline-circle ellipse') : null;
  const aurora = section ? section.querySelector('.ambient-aurora') : null;
  const spotlight = section ? section.querySelector('.wordmark-spotlight') : null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (
    section && stickyChars.length && headline && ellipse &&
    aurora && spotlight
  ) {
    const stepsForChars = stickyChars.length;
    const headlineStartStep = stepsForChars + 2;
    const headlineEndStep = headlineStartStep + 2;
    const circleStartStep = headlineEndStep;
    const circleEndStep = circleStartStep + 4;
    const totalSteps = circleEndStep;

    // Animation belegt nur die ersten 75% des Section-Scrolls. Die letzten
    // 25% sind Settled-State: Spotlight stabil, Aurora weiter dezent
    // driftend.
    const ANIMATION_RANGE = 0.75;
    // Spotlight erreicht seine Endposition leicht nach Animationsende,
    // damit er beim Übergang in den Settled-State sauber "ankommt".
    // Vh-Offsets RELATIV zur sticky-Mitte (50% top): +30vh = 80% des
    // Viewports (unter dem Wordmark), -22vh = 28% (über dem Wordmark).
    const SPOTLIGHT_END = 0.85;
    const SPOTLIGHT_FROM_OFFSET_VH = 30;
    const SPOTLIGHT_TO_OFFSET_VH = -22;

    function clamp01(v) {
      return v < 0 ? 0 : v > 1 ? 1 : v;
    }

    function rangeProgress(progress, startStep, endStep) {
      const a = startStep / totalSteps;
      const b = endStep / totalSteps;
      return clamp01((progress - a) / (b - a));
    }

    function getScrollProgress() {
      const rect = section.getBoundingClientRect();
      const totalScrollDistance = section.offsetHeight - window.innerHeight;
      if (totalScrollDistance <= 0) return 0;
      return clamp01(-rect.top / totalScrollDistance);
    }

    function update() {
      if (reduceMotion) {
        for (const char of stickyChars) char.style.setProperty('--char-progress', '1');
        headline.style.setProperty('--headline-progress', '1');
        headline.classList.add('headline-on');
        ellipse.style.strokeDashoffset = '0';
        aurora.style.setProperty('--aurora-intensity', '0.5');
        spotlight.style.setProperty('--spotlight-offset', '-22vh');
        spotlight.style.setProperty('--spotlight-intensity', '1');
        return;
      }

      const rawProgress = getScrollProgress();
      const progress = Math.min(1, rawProgress / ANIMATION_RANGE);

      for (let i = 0; i < stickyChars.length; i++) {
        const cp = rangeProgress(progress, i, i + 1);
        stickyChars[i].style.setProperty('--char-progress', String(cp));
      }

      const hp = rangeProgress(progress, headlineStartStep, headlineEndStep);
      headline.style.setProperty('--headline-progress', String(hp));
      // Aktiv-Klasse erst ab progress > 0 → vor der Headline-Phase keine
      // var-getriebenen Filter/Shadows, kein Render-Spuk durch den Browser.
      if (hp > 0) {
        headline.classList.add('headline-on');
      } else {
        headline.classList.remove('headline-on');
      }

      const ep = rangeProgress(progress, circleStartStep, circleEndStep);
      ellipse.style.strokeDashoffset = String(100 * (1 - ep));

      aurora.style.setProperty('--aurora-intensity', String(progress));

      // Rising Spotlight: steigt im Viewport von +30vh (unten) auf
      // -22vh (oberhalb Wordmark) relativ zur sticky-Mitte, Intensität
      // 0 → 1. Position über transform — kein Layout-Trigger pro Tick.
      const spotlightProgress = Math.min(1, rawProgress / SPOTLIGHT_END);
      const spotlightOffsetVh =
        SPOTLIGHT_FROM_OFFSET_VH -
        spotlightProgress * (SPOTLIGHT_FROM_OFFSET_VH - SPOTLIGHT_TO_OFFSET_VH);
      spotlight.style.setProperty('--spotlight-offset', `${spotlightOffsetVh}vh`);
      spotlight.style.setProperty('--spotlight-intensity', String(spotlightProgress));
    }

    // Scroll: rAF + dynamischer Cap. Desktop 60fps (16ms), Mobile
    // 30fps (33ms) — die GPU-schweren blurred Layer machen 60fps
    // auf dem Phone unnötig teuer, 30fps fühlt sich gleich smooth an.
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const scrollMinInterval = isMobile ? 33 : 16;
    let ticking = false;
    let lastScrollTime = 0;
    function onScroll() {
      if (ticking) return;
      const now = performance.now();
      if (now - lastScrollTime < scrollMinInterval) return;
      lastScrollTime = now;
      ticking = true;
      window.requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    }

    // Resize: debounce 120ms — die vier blurred Layer (Aurora + Spotlight)
    // sind beim Re-Raster teuer. Lieber einmalig nach dem letzten
    // Resize-Event neu rechnen statt dutzendfach pro Drag.
    let resizeTimer = 0;
    function onResize() {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(update, 120);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    update();
  }
</script>
