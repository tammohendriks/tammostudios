---
// Globales Kontakt-Modal — wird einmal per BaseLayout gemountet,
// state über html[data-modal="contact"] gesteuert. Trigger:
// jedes Element mit data-action="open-contact" auf der Seite.
import { SITE } from '../lib/constants';
---

<div class="contact-modal" id="contact-modal" aria-hidden="true">
  <div class="contact-modal-backdrop" data-close-modal></div>
  <div
    class="contact-modal-card"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <button
      class="contact-modal-close"
      type="button"
      data-close-modal
      aria-label="Modal schließen"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>

    <p class="contact-modal-eyebrow">KONTAKT</p>
    <h2 class="contact-modal-title" id="contact-modal-title">
      Lass uns sprechen.
    </h2>
    <p class="contact-modal-sub">
      Schreib mir direkt. Ich melde mich innerhalb von 24h.
    </p>

    <div class="contact-modal-actions">
      <a
        class="contact-action"
        href={SITE.phoneHref}
      >
        <span class="contact-action-icon" aria-hidden="true">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
          </svg>
        </span>
        <span class="contact-action-text">
          <span class="contact-action-label">Telefon</span>
          <span class="contact-action-value">{SITE.phone}</span>
        </span>
        <svg
          class="contact-action-arrow"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>

      <a
        class="contact-action"
        href={`mailto:${SITE.email}`}
      >
        <span class="contact-action-icon" aria-hidden="true">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
        </span>
        <span class="contact-action-text">
          <span class="contact-action-label">E-Mail</span>
          <span class="contact-action-value">{SITE.email}</span>
        </span>
        <svg
          class="contact-action-arrow"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>

      <a
        class="contact-action"
        href="https://www.instagram.com/tammostudios/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="contact-action-icon" aria-hidden="true">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </span>
        <span class="contact-action-text">
          <span class="contact-action-label">Instagram</span>
          <span class="contact-action-value">@tammostudios</span>
        </span>
        <svg
          class="contact-action-arrow"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  /* Default: Modal komplett aus dem Flow. Wird per html[data-modal=
     "contact"] in BaseLayout aktiviert. Backdrop + Card teilen sich
     den .contact-modal Wrapper (position:fixed, inset:0). */
  .contact-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  :global(html[data-modal="contact"]) .contact-modal {
    display: flex;
  }

  .contact-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    cursor: pointer;
    animation: contact-modal-backdrop-in 200ms ease-out;
  }

  .contact-modal-card {
    position: relative;
    width: 90vw;
    max-width: 480px;
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 40px;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.6),
      0 0 80px rgba(245, 158, 11, 0.12);
    animation: contact-modal-card-in 300ms ease-out;
  }

  @media (max-width: 640px) {
    .contact-modal-card {
      padding: 32px 24px;
    }
  }

  @keyframes contact-modal-backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes contact-modal-card-in {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-modal-backdrop,
    .contact-modal-card {
      animation: none;
    }
  }

  .contact-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: rgba(245, 245, 244, 0.7);
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: color 200ms ease, background 200ms ease;
  }

  .contact-modal-close:hover,
  .contact-modal-close:focus-visible {
    color: rgba(245, 158, 11, 1);
    background: rgba(255, 255, 255, 0.05);
    outline: none;
  }

  .contact-modal-eyebrow {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: rgba(245, 158, 11, 0.95);
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .contact-modal-title {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #f5f5f4;
    margin: 0 0 8px;
  }

  .contact-modal-sub {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(245, 245, 244, 0.65);
    margin: 0 0 28px;
  }

  .contact-modal-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Action-Box: Icon links, Label/Value Mitte, Pfeil rechts.
     Hover ambert den Border + leichten Glow. */
  .contact-action {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    color: #f5f5f4;
    text-decoration: none;
    transition: border-color 200ms ease, background 200ms ease,
                box-shadow 200ms ease;
  }

  .contact-action:hover,
  .contact-action:focus-visible {
    border-color: rgba(245, 158, 11, 0.45);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 24px rgba(245, 158, 11, 0.12);
    outline: none;
  }

  .contact-action-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(245, 158, 11, 0.95);
    flex-shrink: 0;
  }

  .contact-action-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .contact-action-label {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(245, 245, 244, 0.55);
    text-transform: uppercase;
  }

  .contact-action-value {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.95rem;
    color: #f5f5f4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-action-arrow {
    color: rgba(245, 245, 244, 0.35);
    flex-shrink: 0;
    transition: transform 200ms ease, color 200ms ease;
  }

  .contact-action:hover .contact-action-arrow,
  .contact-action:focus-visible .contact-action-arrow {
    color: rgba(245, 158, 11, 0.95);
    transform: translateX(3px);
  }
</style>

<script>
  // Globales Modal-Wiring: alle Trigger mit [data-action="open-contact"]
  // öffnen das Modal, alle [data-close-modal] schließen es. Klick auf
  // den Backdrop schließt; Klick auf die Card propagiert NICHT (sonst
  // würde der Backdrop-Listener feuern). ESC schließt. Body-Scroll wird
  // gesperrt während offen, Focus springt ins Modal und nach Schließen
  // zurück zum Trigger-Element.
  const html = document.documentElement;
  const modal = document.getElementById('contact-modal') as HTMLElement | null;

  if (modal) {
    let lastFocused: HTMLElement | null = null;

    function open() {
      lastFocused = document.activeElement as HTMLElement;
      html.setAttribute('data-modal', 'contact');
      modal!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const closeBtn = modal!.querySelector<HTMLElement>('.contact-modal-close');
      if (closeBtn) closeBtn.focus();
    }

    function close() {
      html.removeAttribute('data-modal');
      modal!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      // Trigger to open
      const trigger = target.closest('[data-action="open-contact"]');
      if (trigger) {
        e.preventDefault();
        open();
        return;
      }

      // Only react to close-clicks while modal is actually open
      if (html.getAttribute('data-modal') !== 'contact') return;

      // Backdrop OR X-Button — beide tragen [data-close-modal].
      // Wichtig: KEIN stopPropagation auf der Card, sonst wird der
      // X-Button-Click verschluckt bevor er hier ankommt. Card-Body-
      // Clicks (Headline, Subline, Action-Boxen) treffen weder
      // Backdrop noch X, finden also kein matching closest() und
      // schließen das Modal nicht.
      const closer = target.closest('[data-close-modal]');
      if (closer) {
        e.preventDefault();
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && html.getAttribute('data-modal') === 'contact') {
        close();
      }
    });
  }
</script>
