---
import { SITE_LABELS, NAV_ITEMS, CTA } from '../lib/constants';

// Auf Sub-Pages "← Startseite" als ersten Eintrag prepended, sodass
// User immer einen klaren Weg zurück hat. Auf der Landing-Page wäre
// der Link redundant — er erscheint dort nicht.
const currentPath = Astro.url.pathname;
const isLanding = currentPath === '/' || currentPath === '/index.html';

type NavItem = { label: string; href: string; isHome?: boolean };
const navItems: NavItem[] = isLanding
  ? [...NAV_ITEMS]
  : [{ label: 'Startseite', href: '/', isHome: true }, ...NAV_ITEMS];

function isActive(href: string) {
  if (href === '/') return isLanding;
  // Sub-Pages: aktiv wenn currentPath mit href beginnt — fängt
  // auch potenzielle Sub-Routes wie /referenzen/foo später ab.
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="topbar" transition:persist="topbar">
  <span class="top-left label-tracked">{SITE_LABELS.establishedLine}</span>

  <nav class="nav" aria-label="Hauptnavigation">
    {navItems.map((item, i) => (
      <span class="nav-item">
        {i > 0 ? <span class="dot" aria-hidden="true"> · </span> : null}
        <a
          class:list={['nav-link', { 'is-home': item.isHome }]}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      </span>
    ))}
  </nav>

  <div class="topbar-right">
    <a class="cta-orbital topbar-cta" href={CTA.href}>
      <span class="cta-label">{CTA.label}</span>
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </a>
    <button
      id="nav-toggle"
      class="hamburger"
      type="button"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" hidden>
  <ul>
    {navItems.map((item) => (
      <li>
        <a
          class:list={['mobile-link', { 'is-home': item.isHome }]}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
    <li class="mobile-cta-wrap">
      <a class="cta-orbital" href={CTA.href}>
        <span class="cta-label">{CTA.label}</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </li>
  </ul>
</div>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Etwas mehr Bottom-Padding, damit der untere CTA-Glow Luft hat. */
    padding: 28px 28px 36px;
    gap: 16px;
    pointer-events: none;
    overflow: visible;
    border-bottom: 1px solid transparent;
    transition:
      background 300ms ease,
      backdrop-filter 300ms ease,
      border-color 300ms ease;
  }

  /* Beim Top der Page transparent. Sobald gescrolled wird (>60px),
     fadet ein subtiler Backdrop ein, damit Nav vor jedem Section-
     Hintergrund lesbar bleibt — z.B. /referenzen scrollt einen
     großen "Referenzen"-Title direkt unter die Nav. */
  :global(html[data-scrolled="true"]) .topbar {
    background: rgba(5, 5, 7, 0.75);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .topbar > * {
    pointer-events: auto;
  }

  /* Splash-Coupling: TopBar-Items sind während Splash + Reveal
     unsichtbar und faden bei "ready" mit den Section-1-Heroes ein.
     Returning visitors mit .splash-skip sehen alles sofort.
     Default-Hidden ist KRITISCH gegen Mobile-FOUC: ohne diese Regel
     blitzt die TopBar im ersten Frame auf, bevor das Splash-Script
     greift. */
  .label-tracked,
  .nav,
  .cta-orbital,
  .hamburger {
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-out;
  }

  :global(html[data-splash="ready"]) .label-tracked,
  :global(html[data-splash="ready"]) .nav,
  :global(html[data-splash="ready"]) .cta-orbital,
  :global(html[data-splash="ready"]) .hamburger,
  :global(html.splash-skip) .label-tracked,
  :global(html.splash-skip) .nav,
  :global(html.splash-skip) .cta-orbital,
  :global(html.splash-skip) .hamburger {
    opacity: 1;
    pointer-events: auto;
  }

  :global(html[data-splash="ready"]) .label-tracked { transition-delay: 0ms;   }
  :global(html[data-splash="ready"]) .nav           { transition-delay: 80ms;  }
  :global(html[data-splash="ready"]) .cta-orbital   { transition-delay: 160ms; }
  :global(html[data-splash="ready"]) .hamburger     { transition-delay: 80ms;  }

  @media (max-width: 767px) {
    .topbar {
      padding: 20px 20px 28px;
    }
  }

  .label-tracked {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
    font-size: 12px;
    color: rgba(245, 245, 244, 0.5);
  }

  .nav {
    display: inline-flex;
    align-items: center;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
  }

  .nav-link {
    color: rgba(245, 245, 244, 0.8);
    font-size: 14px;
    font-weight: 500;
    transition: color 200ms ease;
    padding: 4px 2px;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: rgba(245, 245, 244, 1);
  }

  /* "← Startseite" — Back-Hinweis auf Sub-Pages. Amber gefärbt, mit
     Pfeil-Affordance der bei Hover leicht nach links wandert. */
  .nav-link.is-home {
    color: rgba(245, 158, 11, 0.95);
  }

  .nav-link.is-home::before {
    content: '←';
    margin-right: 4px;
    display: inline-block;
    transition: transform 200ms ease;
  }

  .nav-link.is-home:hover::before,
  .nav-link.is-home:focus-visible::before {
    transform: translateX(-3px);
  }

  /* Aktive Page: amber + bold, damit User auf einen Blick sieht
     wo er ist. */
  .nav-link[aria-current="page"] {
    color: rgba(245, 158, 11, 1);
    font-weight: 600;
  }

  .mobile-link[aria-current="page"] {
    color: rgba(245, 158, 11, 1);
  }

  .mobile-link.is-home {
    color: rgba(245, 158, 11, 0.95);
  }

  .mobile-link.is-home::before {
    content: '← ';
    display: inline;
  }

  .dot {
    color: rgba(245, 245, 244, 0.3);
    padding: 0 6px;
  }

  .topbar-right {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    overflow: visible;
  }

  /* TopBar-spezifische Verkleinerung des globalen .cta-orbital.
     Compact-Padding & 14px-Type, weil der TopBar-CTA neben Nav-
     Links lebt — Closing-CTA in Section 5 darf größer sein. */
  .topbar-cta {
    padding: 11px 26px;
    font-size: 14px;
    gap: 8px;
  }

  /* Hamburger */
  .hamburger {
    width: 40px;
    height: 40px;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    background: transparent;
    border: 0;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ts-fg);
    transition: transform 220ms ease, opacity 220ms ease;
    transform-origin: center;
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile breakpoint */
  @media (max-width: 767px) {
    .nav {
      display: none;
    }
    .hamburger {
      display: inline-flex;
    }
    .label-tracked {
      font-size: 11px;
    }
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 45;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 12, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: menu-enter 220ms ease-out;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .mobile-link {
    color: var(--color-ts-fg);
    font-size: 22px;
    font-weight: 500;
  }

  .mobile-cta-wrap {
    margin-top: 12px;
  }

  @keyframes menu-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      animation: none;
    }
    .hamburger span {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const isOpen = () => !menu.hasAttribute('hidden');
    const open = () => {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });

    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches && isOpen()) close();
    });
  }
</script>
