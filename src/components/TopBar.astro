---
import { SITE_LABELS, NAV_ITEMS, CTA } from '../lib/constants';

// "Startseite" wird IMMER ins DOM gerendert. Sichtbarkeit kommt
// per CSS aus dem html[data-page]- bzw. header[data-page]-State,
// beide werden bei jedem Page-Reload server-seitig korrekt gesetzt.
// Ohne View Transitions: kein Sync nötig, jede Navigation ist ein
// Full-Page-Reload und liefert das richtige data-page direkt vom
// Server.
const currentPath = Astro.url.pathname;
const isLanding = currentPath === '/' || currentPath === '/index.html';
const pageType = isLanding ? 'landing' : 'subpage';

type NavItem = { label: string; href: string; key?: string };
const navItems: NavItem[] = [
  { label: 'Startseite', href: '/', key: 'startseite' },
  ...NAV_ITEMS,
];

function isActive(href: string) {
  if (href === '/') return isLanding;
  // Sub-Pages: aktiv wenn currentPath mit href beginnt — fängt
  // auch potenzielle Sub-Routes wie /referenzen/foo später ab.
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="topbar" data-topbar data-page={pageType}>
  <span class="top-left label-tracked">{SITE_LABELS.establishedLine}</span>

  <nav class="nav" aria-label="Hauptnavigation">
    {navItems.map((item, i) => (
      <span class:list={['nav-item', item.key && `nav-item-${item.key}`]}>
        <a
          class="nav-link"
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
        {i < navItems.length - 1 && (
          <span class="dot" aria-hidden="true"> · </span>
        )}
      </span>
    ))}
  </nav>

  <button
    id="nav-toggle"
    class="hamburger"
    type="button"
    aria-label="Menü öffnen"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span></span>
    <span></span>
  </button>

  <a class="cta-orbital topbar-cta" href={CTA.href}>
    <span class="cta-label">{CTA.label}</span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </a>
</header>

<div id="mobile-menu" class="mobile-menu" hidden>
  <ul>
    {navItems.map((item) => (
      <li class:list={[item.key && `mobile-item-${item.key}`]}>
        <a
          class="mobile-link"
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
    <li class="mobile-cta-wrap">
      <a class="cta-orbital" href={CTA.href}>
        <span class="cta-label">{CTA.label}</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </li>
  </ul>
</div>

<style>
  /* TopBar-Wrapper: 3-Spalten-Grid 1fr/auto/1fr. Die mittlere
     auto-Spalte hat die Breite ihres Inhalts (Nav-Pille bzw. auf
     Mobile der Hamburger); links und rechts sind je 1fr — exakt
     gleich breit, sodass die Mitte garantiert in der Viewport-
     Mitte liegt, egal wie unterschiedlich Eyebrow und CTA in der
     Breite sind. Ohne Grid (flex space-between) hingen die Pillen
     asymmetrisch. */
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 20px 32px;
    gap: 16px;
    pointer-events: none;
    overflow: visible;
  }

  .topbar > * {
    pointer-events: auto;
  }

  .label-tracked {
    grid-column: 1;
    justify-self: start;
  }

  .nav,
  .hamburger {
    grid-column: 2;
    justify-self: center;
  }

  .topbar-cta {
    grid-column: 3;
    justify-self: end;
  }

  /* Splash-Coupling: TopBar-Items sind während Splash + Reveal
     unsichtbar und faden bei "ready" mit den Section-1-Heroes ein.
     Returning visitors mit .splash-skip sehen alles sofort.
     Default-Hidden ist KRITISCH gegen Mobile-FOUC: ohne diese Regel
     blitzt die TopBar im ersten Frame auf, bevor das Splash-Script
     greift. */
  .label-tracked,
  .nav,
  .cta-orbital,
  .hamburger {
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-out;
  }

  :global(html[data-splash="ready"]) .label-tracked,
  :global(html[data-splash="ready"]) .nav,
  :global(html[data-splash="ready"]) .cta-orbital,
  :global(html[data-splash="ready"]) .hamburger,
  :global(html.splash-skip) .label-tracked,
  :global(html.splash-skip) .nav,
  :global(html.splash-skip) .cta-orbital,
  :global(html.splash-skip) .hamburger {
    opacity: 1;
    pointer-events: auto;
  }

  :global(html[data-splash="ready"]) .label-tracked { transition-delay: 0ms;   }
  :global(html[data-splash="ready"]) .nav           { transition-delay: 80ms;  }
  :global(html[data-splash="ready"]) .cta-orbital   { transition-delay: 160ms; }
  :global(html[data-splash="ready"]) .hamburger     { transition-delay: 80ms;  }


  /* Glass-Pill: subtiler dunkler Backdrop mit blur, dünne Border,
     leichter Shadow + inset-Highlight. Wiederverwendet für eyebrow,
     nav und (auf Mobile) hamburger. */
  .label-tracked,
  .nav {
    background: rgba(5, 5, 7, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .label-tracked {
    padding: 10px 18px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 500;
    font-size: 0.7rem;
    color: rgba(245, 245, 244, 0.7);
  }

  .nav {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    gap: 0 4px;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
  }

  .nav-link {
    color: rgba(245, 245, 244, 0.8);
    font-size: 14px;
    font-weight: 500;
    transition: color 200ms ease;
    padding: 4px 2px;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: rgba(245, 245, 244, 1);
  }

  /* Aktive Page: amber + bold, damit User auf einen Blick sieht
     wo er ist. "Startseite" auf Sub-Pages ist KEIN Sonderfall mehr —
     gleicher Stil wie alle anderen Nav-Items, hover ins helle Weiß. */
  .nav-link[aria-current="page"] {
    color: rgba(245, 158, 11, 1);
    font-weight: 600;
  }

  .mobile-link[aria-current="page"] {
    color: rgba(245, 158, 11, 1);
  }

  /* "Startseite" hängt im DOM auf jeder Page, Sichtbarkeit kommt
     aus dem globalen html[data-page]-State. display:none auf Landing
     reserviert KEINEN Layout-Space — der vorherige Ansatz mit
     visibility:hidden hat einen sichtbaren Leerslot vor "Über"
     hinterlassen. Beim Wechsel zu subpage spielt eine einmalige
     @keyframes-Animation, die das Item smooth einblendet. Beim
     Zurück zur Landing verschwindet es ohne Fade-out — bewusst, da
     display:none nicht transitionierbar ist. */
  .nav-item-startseite {
    display: none;
  }

  :global(html[data-page="subpage"]) .nav-item-startseite {
    display: inline-flex;
    align-items: center;
    animation: startseite-fade-in 400ms ease-out;
  }

  @keyframes startseite-fade-in {
    from {
      opacity: 0;
      transform: translateX(-8px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Mobile-Menü: Stack-Layout, gleiches Schema. */
  .mobile-item-startseite {
    display: none;
  }

  :global(html[data-page="subpage"]) .mobile-item-startseite {
    display: list-item;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html[data-page="subpage"]) .nav-item-startseite {
      animation: none;
    }
  }

  .dot {
    color: rgba(245, 245, 244, 0.3);
    padding: 0 6px;
  }

  /* TopBar-spezifische Verkleinerung des globalen .cta-orbital.
     Compact-Padding & 14px-Type, weil der TopBar-CTA neben Nav-
     Links lebt — Closing-CTA in Section 5 darf größer sein. */
  .topbar-cta {
    padding: 11px 26px;
    font-size: 14px;
    gap: 8px;
  }

  /* Hamburger */
  .hamburger {
    width: 40px;
    height: 40px;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    background: transparent;
    border: 0;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ts-fg);
    transition: transform 220ms ease, opacity 220ms ease;
    transform-origin: center;
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile breakpoint: kompaktere Pills, Nav versteckt zugunsten
     Hamburger der seinerseits als Pill rendert. */
  @media (max-width: 767px) {
    .topbar {
      padding: 16px;
    }
    .nav {
      display: none;
    }
    .label-tracked {
      padding: 8px 14px;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
    }
    .hamburger {
      display: inline-flex;
      width: 40px;
      height: 40px;
      padding: 0;
      background: rgba(5, 5, 7, 0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 9999px;
      box-shadow:
        0 4px 24px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 45;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 12, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: menu-enter 220ms ease-out;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .mobile-link {
    color: var(--color-ts-fg);
    font-size: 22px;
    font-weight: 500;
  }

  .mobile-cta-wrap {
    margin-top: 12px;
  }

  @keyframes menu-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      animation: none;
    }
    .hamburger span {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const isOpen = () => !menu.hasAttribute('hidden');
    const open = () => {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });

    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches && isOpen()) close();
    });
  }
</script>
