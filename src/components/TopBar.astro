---
import { SITE_LABELS, NAV_ITEMS, CTA } from '../lib/constants';
---

<header class="topbar" transition:persist="topbar">
  <span class="top-left label-tracked">{SITE_LABELS.establishedLine}</span>

  <nav class="nav" aria-label="Hauptnavigation">
    {NAV_ITEMS.map((item, i) => (
      <span class="nav-item">
        {i > 0 ? <span class="dot" aria-hidden="true"> · </span> : null}
        <a class="nav-link" href={item.href}>{item.label}</a>
      </span>
    ))}
  </nav>

  <div class="topbar-right">
    <a class="cta cta-pill" href={CTA.href}>
      <span class="cta-label">{CTA.label}</span>
      <svg
        class="cta-arrow"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </a>
    <button
      id="nav-toggle"
      class="hamburger"
      type="button"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" hidden>
  <ul>
    {NAV_ITEMS.map((item) => (
      <li>
        <a class="mobile-link" href={item.href}>{item.label}</a>
      </li>
    ))}
    <li class="mobile-cta-wrap">
      <a class="cta-pill" href={CTA.href}>
        <span class="cta-label">{CTA.label}</span>
        <svg
          class="cta-arrow"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </li>
  </ul>
</div>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Etwas mehr Bottom-Padding, damit der untere CTA-Glow Luft hat. */
    padding: 28px 28px 36px;
    gap: 16px;
    pointer-events: none;
    overflow: visible;
  }

  .topbar > * {
    pointer-events: auto;
  }

  @media (max-width: 767px) {
    .topbar {
      padding: 20px 20px 28px;
    }
  }

  .label-tracked {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
    font-size: 12px;
    color: rgba(245, 245, 244, 0.5);
  }

  .nav {
    display: inline-flex;
    align-items: center;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
  }

  .nav-link {
    color: rgba(245, 245, 244, 0.8);
    font-size: 14px;
    font-weight: 500;
    transition: color 200ms ease;
    padding: 4px 2px;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: rgba(245, 245, 244, 1);
  }

  .dot {
    color: rgba(245, 245, 244, 0.3);
    padding: 0 6px;
  }

  .topbar-right {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    overflow: visible;
  }

  .cta-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    overflow: hidden;
    padding: 11px 26px;
    border-radius: 9999px;
    background: linear-gradient(to bottom, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 600;
    /* Ambient stack: inset highlight, kleine Tiefe, mid halo (symmetrisch),
       far-glow. Kein Y-Offset auf den warmen Layern → keine
       "abgeschnittene Unterkante". Baseline ist die Min-Phase des Pulses. */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 2px 8px rgba(0, 0, 0, 0.25),
      0 0 32px rgba(245, 158, 11, 0.30),
      0 0 80px rgba(245, 158, 11, 0.16);
    animation: cta-pulse 2.4s ease-in-out infinite;
    transition: transform 240ms ease, box-shadow 240ms ease;
  }

  .cta-pill::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    /* Belt-and-Suspenders: eigenes border-radius, damit der Shimmer
       auch dann an der Pill-Form bleibt, wenn das Parent-Clipping in
       Kombination mit transform-Pseudo-Elementen mal zickt. */
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.25) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    animation: cta-shimmer 5s ease-in-out infinite;
    pointer-events: none;
  }

  .cta-arrow {
    transform: translateX(0);
    transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .cta-pill:hover {
    /* Pulse stoppen, damit die hover box-shadow den Glow vollständig steuert. */
    animation: none;
    transform: scale(1.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.30),
      0 2px 10px rgba(0, 0, 0, 0.30),
      0 0 48px rgba(245, 158, 11, 0.60),
      0 0 120px rgba(245, 158, 11, 0.30);
  }

  .cta-pill:hover .cta-arrow {
    transform: translateX(4px);
  }

  .cta-pill:hover::before {
    animation-duration: 2s;
  }

  .cta-pill:active {
    transform: scale(0.98);
  }

  .cta-pill:focus-visible {
    outline: 2px solid rgba(245, 158, 11, 0.8);
    outline-offset: 4px;
  }

  /* Pulse: warme Halo-Layer atmen — größerer Swing als zuletzt, damit man's
     wirklich sieht. Blur und Alpha steigen gleichzeitig, der Button "atmet". */
  @keyframes cta-pulse {
    0%, 100% {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.25),
        0 2px 8px rgba(0, 0, 0, 0.25),
        0 0 32px rgba(245, 158, 11, 0.30),
        0 0 80px rgba(245, 158, 11, 0.16);
    }
    50% {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.25),
        0 2px 8px rgba(0, 0, 0, 0.25),
        0 0 56px rgba(245, 158, 11, 0.60),
        0 0 130px rgba(245, 158, 11, 0.32);
    }
  }

  @keyframes cta-shimmer {
    0%, 70% { left: -100%; }
    100%    { left: 200%; }
  }

  /* Hamburger */
  .hamburger {
    width: 40px;
    height: 40px;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    background: transparent;
    border: 0;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ts-fg);
    transition: transform 220ms ease, opacity 220ms ease;
    transform-origin: center;
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile breakpoint */
  @media (max-width: 767px) {
    .nav {
      display: none;
    }
    .hamburger {
      display: inline-flex;
    }
    .label-tracked {
      font-size: 11px;
    }
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 45;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 12, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: menu-enter 220ms ease-out;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .mobile-link {
    color: var(--color-ts-fg);
    font-size: 22px;
    font-weight: 500;
  }

  .mobile-cta-wrap {
    margin-top: 12px;
  }

  @keyframes menu-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-pill {
      animation: none;
      transition: none;
      /* Statisch: mittelhelle Variante, kein Atmen */
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.25),
        0 2px 8px rgba(0, 0, 0, 0.25),
        0 0 40px rgba(245, 158, 11, 0.40),
        0 0 100px rgba(245, 158, 11, 0.22);
    }
    .cta-pill::before {
      animation: none;
      display: none;
    }
    .cta-pill:hover {
      transform: none;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.25),
        0 2px 8px rgba(0, 0, 0, 0.25),
        0 0 40px rgba(245, 158, 11, 0.40),
        0 0 100px rgba(245, 158, 11, 0.22);
    }
    .cta-pill:hover .cta-arrow,
    .cta-arrow {
      transition: none;
      transform: none;
    }
    .mobile-menu {
      animation: none;
    }
    .hamburger span {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const isOpen = () => !menu.hasAttribute('hidden');
    const open = () => {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });

    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches && isOpen()) close();
    });
  }
</script>
