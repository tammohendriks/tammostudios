---
type Position =
  | 'top-left'
  | 'top-right'
  | 'bottom-left'
  | 'bottom-center'
  | 'bottom-right';

interface Props {
  position: Position;
  class?: string;
}

const { position, class: className } = Astro.props;
---

<div class:list={['corner', `corner-${position}`, className]} data-corner={position}>
  <slot />
</div>

<style>
  .corner {
    position: fixed;
    z-index: 5;
    color: rgba(245, 245, 244, 0.6);
    font-size: 13px;
    line-height: 1.4;
  }

  .corner-top-left    { top: 32px;    left: 32px; }
  .corner-top-right   { top: 32px;    right: 32px; }
  .corner-bottom-left { bottom: 32px; left: 32px; }
  .corner-bottom-right { bottom: 32px; right: 32px; }

  .corner-bottom-center {
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
  }

  @media (max-width: 767px) {
    .corner {
      font-size: 11px;
    }
    .corner-top-left    { top: 20px;    left: 20px; }
    .corner-top-right   { top: 20px;    right: 20px; }
    /* Mail (bottom-left) hide on mobile to keep the bottom area uncluttered */
    .corner-bottom-left { display: none; }
    /* Push intro slightly up to leave room for scroll cue beneath it */
    .corner-bottom-center {
      bottom: calc(20px + 28px);
    }
    /* Move scroll-cue under the intro on mobile, centered */
    .corner-bottom-right {
      bottom: 20px;
      right: auto;
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>
