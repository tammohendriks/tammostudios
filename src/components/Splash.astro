---
import { SITE, SITE_LABELS } from '../lib/constants';
import Background from './Background.astro';
import TopBar from './TopBar.astro';
import ScrollCue from './ScrollCue.astro';
---

<script is:inline>
  // Frühe Entscheidung VOR Body-Paint: returning visitor oder reduced-motion?
  // Setzt html.splash-skip → CSS macht alles ab erstem Frame voll sichtbar.
  try {
    if (
      window.sessionStorage.getItem('ts-splash-seen') === '1' ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      document.documentElement.classList.add('splash-skip');
    }
  } catch (e) {}
</script>

<div id="splash-root" data-state="splash">
  <Background />
  <TopBar />

  <main class="hero">
    <h1 class="logo-wrap">
      <img
        src="/logos/logo-full.png"
        alt={SITE.name}
        class="logo-img"
        draggable="false"
        fetchpriority="high"
      />
    </h1>
    <p class="intro">{SITE_LABELS.introText}</p>
  </main>

  <ScrollCue />
</div>

<style is:global>
  /* State-Cascade: global, weil .top-left, .nav, .cta, .scroll-cue
     in Sub-Components leben (eigene Astro-Scopes). */

  #splash-root .background {
    opacity: 0;
    transition: opacity 1.2s ease-out;
  }

  #splash-root[data-state="reveal"] .background,
  #splash-root[data-state="ready"]  .background {
    opacity: 1;
  }

  #splash-root .top-left,
  #splash-root .nav,
  #splash-root .cta,
  #splash-root .intro,
  #splash-root .scroll-cue {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 600ms ease-out, transform 600ms ease-out;
  }

  #splash-root[data-state="ready"] .top-left,
  #splash-root[data-state="ready"] .nav,
  #splash-root[data-state="ready"] .cta,
  #splash-root[data-state="ready"] .intro,
  #splash-root[data-state="ready"] .scroll-cue {
    opacity: 1;
    transform: translateY(0);
  }

  #splash-root[data-state="ready"] .top-left   { transition-delay: 0ms;   }
  #splash-root[data-state="ready"] .nav        { transition-delay: 100ms; }
  #splash-root[data-state="ready"] .cta        { transition-delay: 200ms; }
  #splash-root[data-state="ready"] .intro      { transition-delay: 300ms; }
  #splash-root[data-state="ready"] .scroll-cue { transition-delay: 400ms; }

  /* Returning visitor / reduced-motion → alles sofort, ohne Transition */
  html.splash-skip #splash-root .background,
  html.splash-skip #splash-root .top-left,
  html.splash-skip #splash-root .nav,
  html.splash-skip #splash-root .cta,
  html.splash-skip #splash-root .intro,
  html.splash-skip #splash-root .scroll-cue {
    opacity: 1;
    transform: none;
    transition: none;
  }
</style>

<style>
  .hero {
    position: relative;
    z-index: 5;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    text-align: center;
  }

  .logo-wrap {
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .logo-img {
    display: block;
    height: 30vh;
    width: auto;
    max-width: 80vw;
    filter:
      drop-shadow(0 0 30px rgba(245, 158, 11, 0.20))
      drop-shadow(0 0 60px rgba(245, 158, 11, 0.10));
    animation: logo-glow 6s ease-in-out infinite;
  }

  @media (max-width: 767px) {
    .logo-img {
      height: 22vh;
    }
  }

  @keyframes logo-glow {
    0%, 100% {
      filter:
        drop-shadow(0 0 30px rgba(245, 158, 11, 0.20))
        drop-shadow(0 0 60px rgba(245, 158, 11, 0.10));
    }
    50% {
      filter:
        drop-shadow(0 0 45px rgba(245, 158, 11, 0.30))
        drop-shadow(0 0 90px rgba(245, 158, 11, 0.16));
    }
  }

  .intro {
    margin: 28px 0 0 0;
    max-width: 520px;
    color: rgba(245, 245, 244, 0.7);
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .intro {
      font-size: 13px;
      max-width: 360px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-img {
      animation: none;
    }
  }
</style>

<script>
  // Splash-State-Maschine. Inline-Script oben hat ggf. html.splash-skip gesetzt.
  const wrapper = document.getElementById('splash-root');
  if (wrapper) {
    if (document.documentElement.classList.contains('splash-skip')) {
      wrapper.dataset.state = 'ready';
    } else {
      try { sessionStorage.setItem('ts-splash-seen', '1'); } catch (e) {}
      window.setTimeout(() => { wrapper.dataset.state = 'reveal'; }, 1800);
      window.setTimeout(() => { wrapper.dataset.state = 'ready'; }, 3000);
    }
  }
</script>
