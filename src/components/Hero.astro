---
import { SITE } from '../lib/constants';
---

<section class="hero relative flex min-h-[calc(100dvh-var(--nav-h,140px))] flex-col items-center justify-center px-6 text-center">
  <div class="hero-stack mx-auto max-w-[960px]">
    <p class="eyebrow text-[12px] uppercase tracking-[0.3em] text-ts-muted">
      Freelance Webentwicklung · {SITE.location}
    </p>

    {/* TBD: Hero-Headline final */}
    <h1 class="headline mt-6 font-extrabold text-ts-fg">
      Websites mit <em>Charakter</em>, für Marken die nicht klingen wollen wie alle anderen.
    </h1>

    <p class="subtext mx-auto mt-6 max-w-[640px] text-lg text-ts-fg/80 sm:text-xl">
      Eine Person, ein moderner Stack, sauber gebaut. Astro · Tailwind · Sanity ·
      Vercel — für Bremer Unternehmen die online ankommen wollen wo ihre Kunden
      suchen.
    </p>

    <div class="buttons mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href={`mailto:${SITE.email}`} class="btn-primary">Projekt anfragen</a>
      <a href="/referenzen" class="btn-secondary">Referenzen ansehen</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
  }

  .headline {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .headline em {
    font-style: italic;
    color: var(--color-ts-accent);
    font-weight: inherit;
  }

  .btn-primary {
    display: inline-block;
    padding: 12px 26px;
    border-radius: 9999px;
    background: var(--color-ts-accent);
    color: var(--color-ts-bg);
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  .btn-secondary {
    display: inline-block;
    padding: 12px 26px;
    border-radius: 9999px;
    border: 1px solid rgba(245, 245, 244, 0.25);
    color: var(--color-ts-fg);
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .btn-secondary:hover {
    border-color: rgba(245, 245, 244, 0.6);
    background-color: rgba(245, 245, 244, 0.04);
  }

  .eyebrow,
  .headline,
  .subtext,
  .buttons {
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-up 600ms cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
  }

  .eyebrow  { animation-delay: 200ms; }
  .headline { animation-delay: 400ms; }
  .subtext  { animation-delay: 600ms; }
  .buttons  { animation-delay: 800ms; }

  @keyframes hero-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow,
    .headline,
    .subtext,
    .buttons {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .btn-primary,
    .btn-secondary {
      transition: none;
    }
  }
</style>
