---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../lib/constants';

interface Props {
  pageTitle: string;
  description?: string;
}

const { pageTitle, description = `${SITE.name} — Webentwicklung aus ${SITE.location}.` } = Astro.props;

const fullTitle = `${pageTitle} — ${SITE.name}`;
const allowIndexing = import.meta.env.PUBLIC_ALLOW_INDEXING === 'true';
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const isLanding = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const initialPage = isLanding ? 'landing' : 'subpage';
---

<!doctype html>
<html lang="de" data-page={initialPage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {!allowIndexing && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/png" href="/logos/logo-websiteicon.png" />
    <link rel="apple-touch-icon" href="/logos/logo-websiteicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="theme-color" content="#0a0a0c" />
    <ClientRouter />
    <script is:inline>
      // Splash-State VOR dem ersten Paint UND vor jeder ClientRouter-
      // Navigation neu setzen. Mit View Transitions persistiert <html>
      // zwischen Pages — ohne Reset würde z.B. data-splash="ready" von
      // einer Landing-Navigation weiter auf einer Sub-Page hängen, oder
      // umgekehrt.
      //
      //   Landing + erstes Mal + keine reduced-motion → data-splash="splash"
      //                                                  (Section1-Script
      //                                                  zieht weiter zu
      //                                                  reveal/ready)
      //   Alles andere (Sub-Pages, returning visitor, reduced-motion)
      //                                               → splash-skip
      (function () {
        function applySplashState() {
          try {
            var html = document.documentElement;
            html.classList.remove('splash-skip');
            html.removeAttribute('data-splash');
            var path = window.location.pathname;
            var isLanding = path === '/' || path === '/index.html';
            if (
              !isLanding ||
              window.sessionStorage.getItem('ts-splash-seen') === '1' ||
              window.matchMedia('(prefers-reduced-motion: reduce)').matches
            ) {
              html.classList.add('splash-skip');
            } else {
              html.setAttribute('data-splash', 'splash');
            }
          } catch (e) {}
        }
        applySplashState();
        // before-swap: korrigiert state BEVOR die neue Page gepainted
        // wird, sodass kein "data-splash=ready" von der vorherigen Page
        // kurz die neue Sub-Page treffen kann.
        document.addEventListener('astro:before-swap', applySplashState);
        // page-load: sichert state nach jedem Swap (auch initial).
        document.addEventListener('astro:page-load', applySplashState);
      })();
    </script>
    <script is:inline>
      // TopBar-State-Sync: data-page auf <html> + auf [data-topbar]
      // sowie aria-current pro Nav-Link aktualisieren. Notwendig, weil
      // die TopBar via transition:persist über Page-Wechsel hinweg im
      // DOM erhalten bleibt — ohne dieses Update bliebe data-page beim
      // Wert der zuerst geladenen Page hängen, und "Startseite" würde
      // auf Sub-Pages nicht eingeblendet.
      (function () {
        function updateTopbarState() {
          try {
            var path = window.location.pathname;
            var isLanding = path === '/' || path === '/index.html';
            var pageType = isLanding ? 'landing' : 'subpage';
            document.documentElement.setAttribute('data-page', pageType);
            var topbar = document.querySelector('[data-topbar]');
            if (topbar) topbar.setAttribute('data-page', pageType);

            var links = document.querySelectorAll(
              '[data-topbar] .nav-link, .mobile-menu .mobile-link'
            );
            links.forEach(function (link) {
              var href = link.getAttribute('href') || '';
              var active = false;
              if (href === '/') {
                active = isLanding;
              } else {
                active =
                  path === href || path.indexOf(href + '/') === 0;
              }
              if (active) link.setAttribute('aria-current', 'page');
              else link.removeAttribute('aria-current');
            });
          } catch (e) {}
        }
        updateTopbarState();
        // after-swap feuert nach jedem ClientRouter-Swap, das ist der
        // richtige Moment um die persistierte TopBar an die neue URL
        // anzupassen.
        document.addEventListener('astro:after-swap', updateTopbarState);
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-ts-bg text-ts-fg">
    <slot />
    <script>
      // Site-weiter Scroll-Reveal: alle [data-reveal] Elemente werden
      // beim Eintritt in den Viewport (15% sichtbar) eingefadet. Pro
      // Callback-Batch wird ein 100ms-Stagger zwischen den Elementen
      // gelegt, damit gleichzeitig sichtbar werdende Blöcke nicht
      // synchron, sondern leicht versetzt erscheinen.
      //
      // Mit Astro ClientRouter persistiert der globale Code zwischen
      // Pages — der Listener läuft nur einmal, fired aber bei jedem
      // astro:page-load (initial + nach jeder Navigation). Pro Run
      // wird der vorherige Observer disconnected, sodass keine
      // veralteten Element-Referenzen oder Memory-Leaks entstehen.
      let revealObserver: IntersectionObserver | null = null;

      function setupReveal() {
        if (revealObserver) {
          revealObserver.disconnect();
          revealObserver = null;
        }

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          // Reduced-Motion: Elemente bleiben sichtbar via CSS-Override.
          return;
        }

        const targets = document.querySelectorAll<HTMLElement>(
          '[data-reveal]:not(.is-revealed)'
        );
        if (targets.length === 0) return;

        revealObserver = new IntersectionObserver(
          (entries, observer) => {
            const intersecting = entries.filter((e) => e.isIntersecting);
            intersecting.forEach((entry, i) => {
              const el = entry.target as HTMLElement;
              el.style.transitionDelay = i * 100 + 'ms';
              el.classList.add('is-revealed');
              observer.unobserve(el);
            });
          },
          {
            threshold: 0.15,
            rootMargin: '0px 0px -5% 0px',
          }
        );

        targets.forEach((el) => revealObserver!.observe(el));
      }

      document.addEventListener('astro:page-load', setupReveal);
    </script>
  </body>
</html>
