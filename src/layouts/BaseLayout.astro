---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import { SITE } from '../lib/constants';

interface Props {
  pageTitle: string;
  description?: string;
}

const { pageTitle, description = `${SITE.name} — Webentwicklung aus ${SITE.location}.` } = Astro.props;

const fullTitle = `${pageTitle} — ${SITE.name}`;
const allowIndexing = import.meta.env.PUBLIC_ALLOW_INDEXING === 'true';
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const isLanding = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const initialPage = isLanding ? 'landing' : 'subpage';
---

<!doctype html>
<html lang="de" data-page={initialPage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {!allowIndexing && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/png" href="/logos/logo-websiteicon.png" />
    <link rel="apple-touch-icon" href="/logos/logo-websiteicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="theme-color" content="#0a0a0c" />
    <link
      rel="preload"
      href="/fonts/montreal/NeueMontreal-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/aileron/Aileron-BlackItalic.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <script is:inline>
      // Startseite-Reveal-Flag: setzt einmalig pro Session
      // data-startseite-anim="1" auf <html>, sobald der User von der
      // Landing auf eine Sub-Page wechselt. Die Keyframe-Animation
      // im TopBar-CSS hängt an genau diesem Attribut, sodass das Item
      // beim ERSTEN Sub-Page-Besuch smooth einfadet — bei späteren
      // Sub-Page-Wechseln ist es einfach da, ohne erneutes Re-Triggern.
      // Bei Rückkehr zur Landing wird das Flag gelöscht, sodass der
      // nächste Wechsel wieder eine Animation produziert.
      try {
        var path = window.location.pathname;
        var isLanding = path === '/' || path === '/index.html';
        if (isLanding) {
          window.sessionStorage.removeItem('ts-startseite-shown');
        } else if (!window.sessionStorage.getItem('ts-startseite-shown')) {
          document.documentElement.setAttribute('data-startseite-anim', '1');
          window.sessionStorage.setItem('ts-startseite-shown', '1');
        }
      } catch (e) {}
    </script>
    <script is:inline>
      // Splash-State VOR dem ersten Paint setzen, damit TopBar (außerhalb
      // Section1) und Section1-Inhalte gleichzeitig korrekt rendern.
      // Ohne View Transitions reicht der einmalige Aufruf beim Page-
      // Parse — bei Sub-Page-Navigationen folgt ein Full-Reload, bei
      // dem dieser Block erneut läuft.
      //
      //   Landing + erstes Mal + keine reduced-motion → data-splash="splash"
      //                                                  (Section1-Script
      //                                                  zieht weiter zu
      //                                                  reveal/ready)
      //   Alles andere (Sub-Pages, returning visitor, reduced-motion)
      //                                               → splash-skip
      try {
        var path = window.location.pathname;
        var isLanding = path === '/' || path === '/index.html';
        if (
          !isLanding ||
          window.sessionStorage.getItem('ts-splash-seen') === '1' ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches
        ) {
          document.documentElement.classList.add('splash-skip');
        } else {
          document.documentElement.setAttribute('data-splash', 'splash');
        }
      } catch (e) {}
    </script>
  </head>
  <body class="min-h-dvh bg-ts-bg text-ts-fg">
    <TopBar />
    <slot />
    <script>
      // Site-weiter Scroll-Reveal: alle [data-reveal] Elemente werden
      // beim Eintritt in den Viewport (15% sichtbar) eingefadet. Pro
      // Callback-Batch wird ein 100ms-Stagger zwischen den Elementen
      // gelegt, damit gleichzeitig sichtbar werdende Blöcke nicht
      // synchron, sondern leicht versetzt erscheinen. Initialisiert
      // bei DOMContentLoaded — Full-Page-Reloads triggern das Event
      // bei jeder Navigation neu, kein Astro-Event nötig.
      function setupReveal() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          // Reduced-Motion: Elemente bleiben sichtbar via CSS-Override.
          return;
        }

        const targets = document.querySelectorAll<HTMLElement>(
          '[data-reveal]:not(.is-revealed)'
        );
        if (targets.length === 0) return;

        const observer = new IntersectionObserver(
          (entries, obs) => {
            const intersecting = entries.filter((e) => e.isIntersecting);
            intersecting.forEach((entry, i) => {
              const el = entry.target as HTMLElement;
              el.style.transitionDelay = i * 100 + 'ms';
              el.classList.add('is-revealed');
              obs.unobserve(el);
            });
          },
          {
            threshold: 0.15,
            rootMargin: '0px 0px -5% 0px',
          }
        );

        targets.forEach((el) => observer.observe(el));
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupReveal);
      } else {
        setupReveal();
      }
    </script>
  </body>
</html>
