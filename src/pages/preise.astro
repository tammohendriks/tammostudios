---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import SubPageBackground from '../components/SubPageBackground.astro';
import { SECTION5 } from '../lib/constants';

const { footer } = SECTION5;

// Inline-SVG für Häkchen — kleiner amber-umrandeter Kreis mit
// amber Häkchen innen. Wird in der "Was schon drin ist"-Liste
// pro Item gerendert.
const checkIcon = `
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <circle cx="12" cy="12" r="10" stroke="rgba(245, 158, 11, 0.6)" stroke-width="1.5"/>
    <path d="M8 12.5L11 15.5L16 9" stroke="rgba(245, 158, 11, 1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
`;

const includedItems = [
  'Mobile-Optimierung',
  'Performance-Tuning',
  'SEO-Grundlagen (Meta-Tags, Sitemap, robots.txt, OG-Image)',
  'Kontaktformular mit Mail-Versand',
  'Eigenes CMS für selbstständige Inhaltspflege',
  'Bug-Fixes nach Launch',
];
---

<BaseLayout
  pageTitle="Preise"
  description="1.000 € für eine Website, 2.000 € für einen Online-Shop. Klar, fix, ohne Sternchen."
>
  <TopBar />

  <main class="preise-page" transition:animate="fade">
    <SubPageBackground />

    <header class="preise-hero">
      <h1 class="hero-title">Was es kostet.</h1>
      <p class="hero-subtitle">Klar, fix, ohne Sternchen.</p>
    </header>

    <section class="preise-intro" aria-label="Preise auf einen Blick" data-reveal>
      <p>Eine Website kostet <strong>1.000 €</strong>.</p>
      <p>Ein Online-Shop kostet <strong>2.000 €</strong>.</p>
      <p>Punkt.</p>
    </section>

    <section class="preise-cards" aria-label="Pakete">
      <article class="price-card" data-reveal>
        <p class="price-eyebrow">WEBSITE</p>
        <p class="price-amount">1.000 €</p>
        <p class="price-sublabel">Einmalig. Fix.</p>
        <div class="price-divider"></div>
        <ul class="dash-list">
          <li>Landing + bis zu 5 Unterseiten</li>
          <li>Eigenes CMS unter <code>deinedomain.de/studio</code></li>
          <li>Kontaktformular mit echtem Mail-Versand</li>
          <li>SEO-Grundlagen, Performance, mobile-optimiert</li>
          <li>3 Feedback-Runden inklusive</li>
          <li>Lieferzeit: maximal 14 Tage</li>
        </ul>
        <div class="price-divider"></div>
        <p class="price-payment">
          Zahlung: 50 % bei Auftrag, 50 % bei Launch.<br />
          Bug-Fixes nach Launch: kostenlos.
        </p>
      </article>

      <article class="price-card" data-reveal>
        <p class="price-eyebrow">ONLINE-SHOP</p>
        <p class="price-amount">2.000 €</p>
        <p class="price-sublabel">Einmalig. Fix.</p>
        <div class="price-divider"></div>
        <ul class="dash-list">
          <li>Alles aus dem Website-Paket</li>
          <li>Plus: Produktverwaltung, Warenkorb, Bezahlfunktion</li>
          <li>Lieferzeit: maximal 30 Tage</li>
        </ul>
        <div class="price-divider"></div>
        <p class="price-payment">
          Zahlung: 50 % bei Auftrag, 50 % bei Launch.<br />
          Bug-Fixes nach Launch: kostenlos.
        </p>
      </article>
    </section>

    <section class="preise-section" data-reveal>
      <h2>Erweiterungen</h2>
      <p>Manchmal braucht es mehr.</p>
      <ul class="dash-list">
        <li>Weitere Unterseite: <strong>100 €</strong></li>
        <li>
          Änderungen nach Launch (neue Bilder, Layout-Updates,
          zusätzliche Funktionen): <strong>50 €/Stunde</strong>,
          je nach Umfang
        </li>
      </ul>
      <p>
        Vor jeder Erweiterung gibt's einen klaren
        Aufwand-Schätzwert. Du entscheidest, ob's losgeht.
      </p>
    </section>

    <section class="preise-pflege" aria-label="Pflege-Paket" data-reveal>
      <article class="pflege-card">
        <p class="price-eyebrow">PFLEGE-PAKET</p>
        <div class="pflege-amount-row">
          <p class="pflege-amount">30 €/Monat</p>
          <span class="pflege-tag">optional</span>
        </div>
        <p class="price-sublabel">
          Ohne Mindestlaufzeit. Jederzeit kündbar.
        </p>
        <div class="price-divider"></div>
        <ul class="dash-list">
          <li>Hosting & Domain-Verwaltung</li>
          <li>Sicherheits-Updates</li>
          <li>
            30 Minuten kleine Änderungen pro Monat (Texte, Bilder,
            Öffnungszeiten)
          </li>
          <li>Priorität bei Anfragen</li>
          <li>Automatische Backups</li>
        </ul>
        <div class="price-divider"></div>
        <p class="pflege-closing">
          Wenn Du Dich nicht festlegen willst: musst Du nicht. Das
          Paket lässt sich auch erst Monate nach Launch starten —
          oder gar nicht.
        </p>
      </article>
    </section>

    <section class="preise-section preise-included" data-reveal>
      <h2>Was schon drin ist</h2>
      <p>
        Damit Du weißt, was Du bekommst, ohne dass am Ende eine
        Rechnung auftaucht:
      </p>
      <ul class="check-list">
        {includedItems.map((item) => (
          <li>
            <span class="check-icon" set:html={checkIcon} />
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p>
        Das ist alles drin. Keine versteckten Kosten, keine
        „Premium-Tier"-Fallen.
      </p>
    </section>

    <section class="preise-section preise-manifest" data-reveal>
      <h2>Warum diese Preise so klar sind?</h2>
      <p>
        Ich glaube an einfache Verhältnisse. Du sollst vorher
        wissen, was Deine Website kostet — nicht hinterher mit
        Zusatzposten überrascht werden. Was hier steht, ist was
        Du zahlst. Mehr nicht.
      </p>
      <p class="lock-in">
        Wer jetzt mit mir startet, bleibt zu diesen Konditionen
        — auch wenn die Preise später steigen.
      </p>
    </section>

    <section class="preise-cta" data-reveal>
      <p class="cta-pre">Klingt fair?</p>
      <a class="inline-link inline-link-cta" href="/kontakt">
        <span>Lass uns sprechen</span>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-row">
      <span class="footer-brand">{footer.brand}</span>
      <nav class="footer-nav" aria-label="Hauptnavigation">
        {footer.navLinks.map((link, i) => (
          <>
            {i > 0 && <span aria-hidden="true">·</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </nav>
    </div>
    <div class="footer-row footer-row-legal">
      <span class="footer-copy">{footer.copyright}</span>
      <nav class="footer-legal" aria-label="Rechtliches">
        {footer.legalLinks.map((link, i) => (
          <>
            {i > 0 && <span aria-hidden="true">·</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .preise-page {
    position: relative;
    background: #050507;
    padding: 140px 40px 80px;
    min-height: calc(100vh - 200px);
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .preise-page {
      padding: 100px 20px 60px;
    }
  }

  /* Atmosphäre liegt jetzt in <SubPageBackground /> — geteilt mit
     /ueber und /referenzen. */

  /* === Hero === */
  .preise-hero {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto 80px;
    padding-top: 32px;
  }

  .hero-title {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #f5f5f4;
    margin: 0 0 18px;
  }

  .hero-subtitle {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.55;
    color: rgba(245, 245, 244, 0.65);
    margin: 0;
  }

  /* === Intro-Statement: drei Zeilen, Preise in Amber === */
  .preise-intro {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto 96px;
    text-align: center;
  }

  .preise-intro p {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 600;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: #f5f5f4;
    margin: 0 0 6px;
  }

  .preise-intro p:last-child {
    margin: 12px 0 0;
    font-weight: 700;
    color: rgba(245, 245, 244, 0.55);
  }

  .preise-intro strong {
    color: rgba(245, 158, 11, 1);
    font-weight: 700;
  }

  /* === Zwei Hauptkarten === */
  .preise-cards {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto 96px;
  }

  @media (max-width: 768px) {
    .preise-cards {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 72px;
    }
  }

  .price-card {
    background: rgba(15, 15, 18, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 40px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 300ms ease;
    display: flex;
    flex-direction: column;
  }

  .price-card:hover,
  .price-card:focus-within {
    border-color: rgba(245, 158, 11, 0.4);
  }

  @media (max-width: 768px) {
    .price-card {
      padding: 28px;
      border-radius: 16px;
    }
  }

  .price-eyebrow {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: rgba(245, 158, 11, 0.95);
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .price-amount {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #f5f5f4;
    margin: 0 0 6px;
  }

  .price-sublabel {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(245, 245, 244, 0.55);
    margin: 0;
  }

  .price-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 24px 0;
  }

  .price-payment {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(245, 245, 244, 0.6);
    margin: 0;
  }

  /* === Em-Dash-Liste — kein Bullet-Symbol, stattdessen "—"
     als ::before. Wiederverwendet von price-card features,
     Erweiterungen, Pflege-Paket. */
  .dash-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dash-list li {
    position: relative;
    padding-left: 22px;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(245, 245, 244, 0.85);
  }

  .dash-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(245, 158, 11, 0.85);
    font-weight: 500;
  }

  .dash-list strong {
    color: #f5f5f4;
    font-weight: 600;
  }

  .dash-list code {
    font-family: 'SF Mono', Monaco, monospace;
    font-size: 0.92em;
    color: rgba(245, 158, 11, 0.95);
    background: rgba(245, 158, 11, 0.08);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* === Erweiterungen + Manifest + Included: gleiche
     Section-Spalte mit Amber-Bar-Headline wie auf /ueber */
  .preise-section {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto 80px;
  }

  .preise-section h2 {
    position: relative;
    padding-left: 18px;
    margin: 0 0 20px;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: #f5f5f4;
  }

  .preise-section h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 3px;
    background: rgba(245, 158, 11, 0.9);
    border-radius: 2px;
  }

  .preise-section p {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: clamp(1.05rem, 1.15vw, 1.125rem);
    line-height: 1.7;
    color: rgba(245, 245, 244, 0.78);
    margin: 0 0 18px;
  }

  .preise-section .dash-list {
    margin: 18px 0;
  }

  /* === Pflege-Karte: eigenständig, dezenter als Hauptkarten === */
  .preise-pflege {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto 80px;
  }

  .pflege-card {
    background: rgba(10, 10, 12, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 36px;
  }

  @media (max-width: 768px) {
    .pflege-card {
      padding: 24px;
    }
  }

  .pflege-amount-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin: 0 0 6px;
  }

  .pflege-amount {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: #f5f5f4;
    margin: 0;
  }

  .pflege-tag {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 245, 244, 0.5);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    padding: 4px 10px;
  }

  .pflege-closing {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(245, 245, 244, 0.6);
    margin: 0;
  }

  /* === "Was schon drin ist" — Häkchen-Liste === */
  .check-list {
    list-style: none;
    margin: 24px 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 32px;
  }

  @media (max-width: 768px) {
    .check-list {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(245, 245, 244, 0.85);
  }

  .check-icon {
    display: inline-flex;
    flex-shrink: 0;
    margin-top: 3px;
  }

  /* === Lock-in-Satz im Manifest: amber Border links + leichte
     Einrückung. Italic gibt der Aussage zusätzliches Gewicht ohne
     einen Pill-Button bauen zu müssen. */
  .lock-in {
    border-left: 3px solid rgba(245, 158, 11, 0.7);
    padding-left: 18px;
    font-style: italic;
    color: rgba(245, 245, 244, 0.92) !important;
    margin: 24px 0 0 !important;
  }

  /* === CTA-Schluss: leiser, kein Pill === */
  .preise-cta {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 0 16px;
  }

  .cta-pre {
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(245, 245, 244, 0.55);
    margin: 0 0 16px;
  }

  .inline-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #f5f5f4;
    text-decoration: none;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 200ms ease, color 200ms ease;
  }

  .inline-link svg {
    color: rgba(245, 158, 11, 0.95);
    transition: transform 200ms ease;
    flex-shrink: 0;
  }

  .inline-link:hover,
  .inline-link:focus-visible {
    border-bottom-color: rgba(245, 158, 11, 0.6);
    color: #fff;
    outline: none;
  }

  .inline-link:hover svg,
  .inline-link:focus-visible svg {
    transform: translateX(3px);
  }

  .inline-link-cta {
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    font-weight: 600;
  }

  /* Footer (gleicher Stil wie /referenzen + /ueber) */
  .site-footer {
    background: #050507;
    padding: 32px 40px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 24px;
    font-family: 'Neue Montreal', 'Inter', sans-serif;
    font-size: 0.78rem;
  }

  .footer-brand {
    color: rgba(245, 245, 244, 0.7);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .footer-copy {
    color: rgba(245, 245, 244, 0.5);
  }

  .footer-nav,
  .footer-legal {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-nav a,
  .footer-legal a {
    color: rgba(245, 245, 244, 0.7);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-nav a:hover,
  .footer-nav a:focus-visible,
  .footer-legal a:hover,
  .footer-legal a:focus-visible {
    color: rgba(245, 158, 11, 0.95);
    outline: none;
  }

  .footer-row-legal {
    color: rgba(245, 245, 244, 0.4);
    font-size: 0.72rem;
  }

  @media (max-width: 768px) {
    .footer-row {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: 4px 12px;
      font-size: 0.65rem;
    }
    .footer-row-legal {
      font-size: 0.6rem;
      opacity: 0.7;
    }
  }
</style>
