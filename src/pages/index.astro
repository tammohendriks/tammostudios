---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Section1 from '../components/sections/Section1.astro';
import Section2 from '../components/sections/Section2.astro';
import Section3 from '../components/sections/Section3.astro';
import Section4 from '../components/sections/Section4.astro';
import { SITE } from '../lib/constants';
---

<BaseLayout
  pageTitle="Webentwicklung mit Charakter"
  description={`${SITE.name} — Webentwicklung aus ${SITE.location}.`}
>
  <TopBar />

  <main>
    <Section1 />
    <Section2 />
    <Section3 />
    <Section4 />
  </main>
</BaseLayout>
